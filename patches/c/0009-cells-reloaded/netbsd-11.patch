+	if (lua_gettop(L) >= 2 && !lua_isnil(L, 2)) {
+		luaL_checktype(L, 2, LUA_TTABLE);
+		copy_opt_field_raw(L, 2, -1, "args");
+		copy_opt_field_raw(L, 2, -1, "env");
+		copy_opt_field_raw(L, 2, -1, "cwd");
+		copy_opt_field_raw(L, 2, -1, "timeout");
