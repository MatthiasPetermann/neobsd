+  options.dsl_dir = NULL;
+  cellman_api_result_init(&result);
+  rc = cellman_api_cell_start(&options, name, all, &result);
+  rc = api_result_to_status(rc, &result, err_out);
+  cellman_api_result_reset(&result);
+  return rc;
