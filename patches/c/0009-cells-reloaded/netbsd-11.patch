+static const char *
+cell_snapshot_state(bool manifest_present, bool rendered, bool desired_running)
+{
+	if (manifest_present) {
+		if (rendered)
+			return desired_running ? "managed" : "parked";
+		return desired_running ? "pending" : "declared";
+	}
+
+	if (rendered)
+		return "orphaned";
+	return "absent";
+}
