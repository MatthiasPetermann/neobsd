+static bool
+string_list_contains(const struct cellman_string_list *list, const char *value)
+{
+	size_t i;
+
+	if (list == NULL || value == NULL)
+		return false;
+
+	for (i = 0; i < list->len; i++) {
+		if (strcmp(list->items[i], value) == 0)
+			return true;
