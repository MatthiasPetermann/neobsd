+/*
+ * List overlay backup archives for one cell.
+ */
+int
+cellman_backup_cell_list(const char *name, bool tsv, bool no_header, char **err)
+{
+	struct backup_entry_list entries;
+	size_t i;
+
+	if (!resource_name_valid(name)) {
