+static bool
+parse_action_pkg(lua_State *L, int idx, struct cellman_action *action,
+    char **err)
+{
+	lua_getfield(L, idx, "packages");
+	if (!lua_istable(L, -1)) {
+		lua_pop(L, 1);
+		if (err != NULL)
+			*err = cellman_xasprintf(NULL,
+			    "pkg action requires packages array");
+		return false;
