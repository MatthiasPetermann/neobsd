+#	$NetBSD$
+#
+# /etc/cellman.conf -- defaults for cellman(8)
+#
+# RELEASE and MACHINE_ARCH can be left empty to auto-detect from the
+# running host (recommended).
+#
+# If RELEASE is set explicitly, use a valid NetBSD release directory name
+# (e.g. 11.0, 11.0_RC1). Avoid branch/source suffixes like _STABLE.
+#
+
+RELEASE=
+MACHINE_ARCH=
+
+# Optional override. If unset/empty, cellman derives:
+# https://cdn.netbsd.org/pub/NetBSD/NetBSD-${RELEASE}/${MACHINE_ARCH}/binary/sets
+NETBSD_MIRROR=""
+
+CELL_BASE_DIR=/var/cellman/base
+CELL_DATA_DIR=/var/cellman/cells
+CELL_VOLUME_DIR=/var/cellman/volumes
+CELL_BACKUP_DIR=/var/backups/cellman
+CELL_RELEASE_DIR=/var/cellman/releases
+
+# Allow mount specs with absolute host paths in cell mount declarations
+# (for example /srv/storage:/data:rw). Keep NO to restrict mounts
+# to named volumes managed by cellman.
+CELL_ALLOW_HOST_MOUNTS=NO
+
+# Package source for declarative apply actions.
+# PKG_RELEASE is normalized to major.minor by default (without suffixes).
+# Example normalized path:
+#   http://cdn.NetBSD.org/pub/pkgsrc/packages/NetBSD/x86_64/11.0/All
+PKG_MIRROR=http://cdn.NetBSD.org/pub/pkgsrc/packages/NetBSD
+PKG_ARCH=
+PKG_RELEASE=
+PKG_PATH=
+
+# Cellman specifications are read from /etc/cellman/*.lua by default.
+# Override at runtime with the CELLMAN_DSL_DIR environment variable.
+
+# Per-cell local /dev setup (tmpfs + MAKEDEV)
+CELL_LOCAL_DEV=YES
+CELL_DEV_SIZE=8m
+CELL_DEVICES="std ptm"
+CELL_PTYFS=YES
