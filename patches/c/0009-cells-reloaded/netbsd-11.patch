index 000000000000..543c010809ec
--- /dev/null
+++ b/usr.sbin/cellman/examples/ticketd/assets/ticketd
@@ -0,0 +1,24 @@
+#!/bin/sh
+set -eu
+
+config=
+while [ "$#" -gt 0 ]; do
+  case "$1" in
+    -config)
+      shift
+      config="${1:-}"
+      ;;
+  esac
+  shift || true
+done
+
+if [ -z "$config" ] || [ ! -f "$config" ]; then
+  echo "ticketd: missing or unreadable config file" >&2
+  exit 1
+fi
+
+echo "ticketd: demo launcher running with config $config"
+trap 'exit 0' INT TERM
+while :; do
+  sleep 300
+done
