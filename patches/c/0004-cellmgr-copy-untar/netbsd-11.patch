+# UNTAR ./assets/site-content.tar.gz /var/www/example strip=1
 EXEC [ -f /var/www/example/.bootstrapped ] || touch /var/www/example/.bootstrapped
 FILE_BEGIN /var/www/example/index.html mode=0644
