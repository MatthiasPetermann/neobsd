+validate_gid_csv() {
+	gid_csv=$1
+	gid_origin=$2
+	[ -n "${gid_csv}" ] || return 0
+	if ! printf '%s\n' "${gid_csv}" | awk -F',' '
+		{
+			if (NF < 1)
+				exit 1
+			for (i = 1; i <= NF; i++) {
+				if ($i !~ /^[0-9]+$/)
+					exit 1
+			}
+		}
+	'; then
+		echo "${gid_origin}: invalid gid list '${gid_csv}'" >&2
+		return 1
+	fi
+	return 0
+}
+
+validate_cell_supervise_run_as() {
+	run_as_spec=${1:-}
+	run_as_origin=${2:-run-as}
+	CELL_SUPERVISE_RUN_AS_NORMALIZED=
+
+	[ -n "${run_as_spec}" ] || return 0
+
+	case "${run_as_spec}" in
+	uid:*)
+		run_as_body=${run_as_spec#uid:}
+		set -f
+		run_as_old_ifs=${IFS}
+		IFS=:
+		set -- ${run_as_body}
+		IFS=${run_as_old_ifs}
+		set +f
+
+		if [ $# -eq 1 ]; then
+			run_as_uid=$1
+			run_as_gid=
+		elif [ $# -eq 2 ]; then
+			run_as_uid=$1
+			run_as_gid=$2
+		else
+			echo "${run_as_origin}: invalid --run-as '${run_as_spec}' (expected uid:uid[:gid])" >&2
+			return 1
+		fi
+
+		case "${run_as_uid}" in
+		""|*[!0-9]*)
+			echo "${run_as_origin}: invalid uid in --run-as '${run_as_spec}'" >&2
+			return 1
+			;;
+		esac
+		case "${run_as_gid}" in
+		"" )
+			CELL_SUPERVISE_RUN_AS_NORMALIZED="uid:${run_as_uid}"
+			return 0
+			;;
+		*[!0-9]*)
+			echo "${run_as_origin}: invalid gid in --run-as '${run_as_spec}'" >&2
+			return 1
+			;;
+		esac
+		CELL_SUPERVISE_RUN_AS_NORMALIZED="uid:${run_as_uid}:${run_as_gid}"
+		return 0
+		;;
+	host:*)
+		run_as_body=${run_as_spec#host:}
+		set -f
+		run_as_old_ifs=${IFS}
+		IFS=:
+		set -- ${run_as_body}
+		IFS=${run_as_old_ifs}
+		set +f
+
+		if [ $# -eq 1 ]; then
+			run_as_user=$1
+			run_as_group=
+		elif [ $# -eq 2 ]; then
+			run_as_user=$1
+			run_as_group=$2
+		else
+			echo "${run_as_origin}: invalid --run-as '${run_as_spec}' (expected host:user[:group])" >&2
+			return 1
+		fi
+
+		case "${run_as_user}" in
+		""|*[!A-Za-z0-9._-]*)
+			echo "${run_as_origin}: invalid user in --run-as '${run_as_spec}'" >&2
+			return 1
+			;;
+		esac
+		case "${run_as_group}" in
+		"" )
+			CELL_SUPERVISE_RUN_AS_NORMALIZED="host:${run_as_user}"
+			return 0
+			;;
+		*[!A-Za-z0-9._-]*)
+			echo "${run_as_origin}: invalid group in --run-as '${run_as_spec}'" >&2
+			return 1
+			;;
+		esac
+		CELL_SUPERVISE_RUN_AS_NORMALIZED="host:${run_as_user}:${run_as_group}"
+		return 0
+		;;
+	*)
+		echo "${run_as_origin}: invalid --run-as '${run_as_spec}' (expected host:user[:group] or uid:uid[:gid])" >&2
+		return 1
+		;;
+	esac
+}
+
+resolve_host_group_gid() {
+	run_as_group=$1
+	case "${run_as_group}" in
+	"" )
+		echo "resolve group gid: empty group" >&2
+		return 1
+		;;
+	*[!0-9]*)
+		run_as_gid=
+		if command -v getent >/dev/null 2>&1; then
+			run_as_gid=$(getent group "${run_as_group}" 2>/dev/null |
+			    awk -F: 'NR == 1 { print $3; exit }')
+		fi
+		if [ -z "${run_as_gid}" ] && [ -r /etc/group ]; then
+			run_as_gid=$(awk -F: -v g="${run_as_group}" '$1 == g { print $3; exit }' /etc/group)
+		fi
+		case "${run_as_gid}" in
+		""|*[!0-9]*)
+			echo "unable to resolve group '${run_as_group}' to numeric gid" >&2
+			return 1
+			;;
+		esac
+		printf '%s\n' "${run_as_gid}"
+		return 0
+		;;
+	*)
+		printf '%s\n' "${run_as_group}"
+		return 0
+		;;
+	esac
+}
+
+resolve_cell_supervise_run_as() {
+	run_as_spec=${1:-}
