+
+  marker_width = name_width;
+  max_marked_payload = (int)sizeof(name_marked) - 2;
+  if (max_marked_payload < 0) {
+    max_marked_payload = 0;
+  }
+  if (!row->manifest_present && marker_width > 1) {
+    marker_width -= 1;
