+remove_manifest_cell() {
+	need_root
+	name=$1
+	assert_valid_cell_name "${name}"
+
+	manifest_cell_paths "${name}"
+	if [ ! -f "${MANIFEST_CELL_CONF}" ] && [ ! -f "${MANIFEST_APPLY_FILE}" ]; then
+		echo "manifest cell not found: ${name}" >&2
+		exit 1
+	fi
+
+	rm -f "${MANIFEST_CELL_CONF}" "${MANIFEST_APPLY_FILE}"
+	echo "Removed manifest cell ${name}"
+}
+
+remove_manifest_all() {
+	need_root
+
+	names=
+	for cell_conf in "${MANIFEST_DIR}"/*.cell; do
+		[ -f "${cell_conf}" ] || continue
+		name=${cell_conf##*/}
+		name=${name%.cell}
+		names="${names} ${name}"
+	done
+
+	for apply_file in "${MANIFEST_DIR}"/*.apply; do
+		[ -f "${apply_file}" ] || continue
+		name=${apply_file##*/}
+		name=${name%.apply}
+		if ! word_list_contains "${name}" "${names}"; then
+			names="${names} ${name}"
+		fi
+	done
+
+	set -- ${names}
+	if [ $# -eq 0 ]; then
+		echo "No manifests found to remove"
+		return
+	fi
+	if ! confirm_data_loss "Removing all manifest cell definitions from ${MANIFEST_DIR}"; then
+		exit 1
+	fi
+
+	removed=0
+	for name in "$@"; do
+		remove_manifest_cell "${name}"
+		removed=$((removed + 1))
+	done
+	echo "Removed ${removed} cell manifests"
+}
+
+prune_runtime_cell() {
+	need_root
+	name=$1
+	assert_valid_cell_name "${name}"
+	cell_paths "${name}"
+
+	if [ ! -d "${CELL_DIR}" ]; then
+		echo "runtime cell not found: ${name}" >&2
+		exit 1
+	fi
+
+	if command -v cellctl >/dev/null 2>&1; then
+		if cell_exists "${name}"; then
+			cid=$(cell_cid_by_name "${name}" || true)
+			if [ -n "${cid}" ]; then
+				stop_cell_processes "${name}" "${cid}"
+				cellctl destroy "${cid}"
+			fi
+		fi
+	fi
+
+	if [ -r "${CELL_CONF}" ]; then
+		load_cell_conf "${name}"
+	else
+		CELL_VOLUME_MOUNTS=
+	fi
+
+	if [ -d "${ROOT_DIR}" ]; then
+		umount_cell_root || true
+	fi
+
+	rm -rf "${CELL_DIR}"
+	echo "Pruned runtime cell ${name}"
+}
+
+prune_runtime_all() {
+	need_root
+	mode=${1:-all}
+
+	case "${mode}" in
+	all|orphans)
+		;;
+	*)
+		echo "invalid prune mode: ${mode}" >&2
+		exit 1
+		;;
+	esac
+
+	names=
+	if [ -d "${CELL_DATA_DIR}" ]; then
+		for cell_dir in "${CELL_DATA_DIR}"/*; do
+			[ -d "${cell_dir}" ] || continue
+			name=${cell_dir##*/}
+			case "${name}" in
+			*[!A-Za-z0-9._-]*)
+				echo "Skipping invalid runtime cell directory ${cell_dir}" >&2
+				continue
+				;;
+			esac
+			if [ "${mode}" = "orphans" ]; then
+				manifest_cell_paths "${name}"
+				if [ -f "${MANIFEST_CELL_CONF}" ]; then
+					continue
+				fi
+			fi
+			names="${names} ${name}"
+		done
+	fi
+
+	set -- ${names}
+	if [ $# -eq 0 ]; then
+		if [ "${mode}" = "orphans" ]; then
+			echo "No orphan runtime cells found to prune"
+		else
+			echo "No runtime cells found to prune"
+		fi
+		return
+	fi
+	if [ "${mode}" = "orphans" ]; then
+		if ! confirm_data_loss "Pruning orphan runtime cells under ${CELL_DATA_DIR}"; then
+			exit 1
+		fi
+	else
+		if ! confirm_data_loss "Pruning all runtime cells under ${CELL_DATA_DIR}"; then
+			exit 1
+		fi
+	fi
+
+	pruned=0
+	for name in "$@"; do
+		prune_runtime_cell "${name}"
+		pruned=$((pruned + 1))
+	done
+
+	if [ "${mode}" = "orphans" ]; then
+		echo "Pruned ${pruned} orphan runtime cells"
+		return
+	fi
+	echo "Pruned ${pruned} runtime cells"
+}
+
+file_hash() {
+	path=$1
+	if command -v sha256 >/dev/null 2>&1; then
+		sha256 -q "${path}"
+		return
+	fi
+	if command -v sha256sum >/dev/null 2>&1; then
+		sha256sum "${path}" | awk '{print $1}'
+		return
+	fi
+	cksum "${path}" | awk '{print $1 "-" $2}'
+}
+
+state_read() {
+	state_file=$1
+	if [ -r "${state_file}" ]; then
+		cat "${state_file}"
+	fi
+	return 0
+}
+
+state_write() {
+	state_file=$1
+	value=$2
+	mkdir -p "$(dirname "${state_file}")"
+	printf '%s\n' "${value}" > "${state_file}"
+}
+
+cell_monitor_pid() {
+	name=$1
+	cid=$2
+	ps -axo pid,command | awk -v n="${name}" -v j="${cid}" '
+		$0 ~ "cellctl supervise cell=" n " cid=" j { print $1; exit }
+	'
+}
+
+stop_cell_processes() {
+	name=$1
+	cid=$2
+	monitor_pid=$(cell_monitor_pid "${name}" "${cid}" || true)
+
+	# A cell can be alive without an active supervise process (e.g. it already
+	# exited). In that case we still want stop_cell() to continue with destroy.
+	[ -n "${monitor_pid}" ] || return 0
+
+	kill -TERM "${monitor_pid}" >/dev/null 2>&1 || true
+	sleep 1
+	kill -KILL "${monitor_pid}" >/dev/null 2>&1 || true
+}
