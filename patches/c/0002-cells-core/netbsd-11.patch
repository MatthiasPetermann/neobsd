+#    notice, this list of conditions and the following disclaimer.
+# 2. Redistributions in binary form must reproduce the above copyright
+#    notice, this list of conditions and the following disclaimer in the
+#    documentation and/or other materials provided with the distribution.
+#
+# THIS SOFTWARE IS PROVIDED BY THE NETBSD FOUNDATION, INC. AND CONTRIBUTORS
+# ``AS IS'' AND ANY EXPRESS OR IMPLIED WARRANTIES, INCLUDING, BUT NOT LIMITED
+# TO, THE IMPLIED WARRANTIES OF MERCHANTABILITY AND FITNESS FOR A PARTICULAR
+# PURPOSE ARE DISCLAIMED.  IN NO EVENT SHALL THE FOUNDATION OR CONTRIBUTORS
+# BE LIABLE FOR ANY DIRECT, INDIRECT, INCIDENTAL, SPECIAL, EXEMPLARY, OR
+# CONSEQUENTIAL DAMAGES (INCLUDING, BUT NOT LIMITED TO, PROCUREMENT OF
+# SUBSTITUTE GOODS OR SERVICES; LOSS OF USE, DATA, OR PROFITS; OR BUSINESS
+# INTERRUPTION) HOWEVER CAUSED AND ON ANY THEORY OF LIABILITY, WHETHER IN
+# CONTRACT, STRICT LIABILITY, OR TORT (INCLUDING NEGLIGENCE OR OTHERWISE)
+# ARISING IN ANY WAY OUT OF THE USE OF THIS SOFTWARE, EVEN IF ADVISED OF THE
+# POSSIBILITY OF SUCH DAMAGE.
+#
+# secmodel_cell, cellctl, and cellmgr designed and implemented by
+# Matthias Petermann, inspired by FreeBSD cells.
+#
+# Build and manage cellctl cells with a shared read-only base layer.
+#
+# Layout:
+#   /var/cellmgr/releases/<release>/<arch>/{base,etc[,xbase]}.tar.xz
+#   /var/cellmgr/base/<release>-<arch>/
+#   /var/cellmgr/cells/<name>/{root,overlay}
+#
+# Config:
+#   /etc/cellmgr.conf
+#
+# Requires root, cellctl, tar, and mount_null.
+
+set -eu
+
+PATH=/sbin:/bin:/usr/sbin:/usr/bin
+
+CONF_FILE=${CELLMGR_CONF:-/etc/cellmgr.conf}
+
+detect_release() {
+	# Derive a release token from uname -r suitable for set URLs.
+	# Keep official release tags like _RC* / _BETA*, but drop build/source
+	# branch suffixes like _STABLE.
+	rel=$(uname -r)
+	rel=$(printf '%s' "${rel}" | sed -e 's/[^A-Za-z0-9._-].*$//')
+
+	case "${rel}" in
+	*_[Rr][Cc]*|*_[Bb][Ee][Tt][Aa]*)
+		# Keep prerelease tag (e.g. 11.0_RC1).
+		:
+		;;
+	*_* )
+		# Drop non-release suffixes (e.g. _STABLE, _current snapshot tags).
+		rel=${rel%%_*}
+		:
+		;;
+	esac
+
+	major=${rel%%.*}
+	if [ -z "${major}" ] || [ "${major}" = "${rel}" ]; then
+		echo "failed to detect running NetBSD release from uname -r (${rel})" >&2
+		exit 1
+	fi
+
+	rest=${rel#*.}
+	minor=${rest%%.*}
+	if [ -z "${minor}" ]; then
+		echo "failed to detect NetBSD release minor from uname -r (${rel})" >&2
+		exit 1
+	fi
+
+	printf '%s.%s\n' "${major}" "${minor}"
+}
+
+normalize_release_major_minor() {
+	input=$1
+	rel=$(printf '%s' "${input}" | sed -e 's/[^A-Za-z0-9._-].*$//')
+	rel=${rel%%_*}
+
+	major=${rel%%.*}
+	if [ -z "${major}" ] || [ "${major}" = "${rel}" ]; then
+		echo "failed to normalize release (${input})" >&2
+		exit 1
+	fi
+
+	rest=${rel#*.}
+	minor=${rest%%.*}
+	if [ -z "${minor}" ]; then
+		echo "failed to normalize release minor (${input})" >&2
+		exit 1
+	fi
+
+	printf '%s.%s\n' "${major}" "${minor}"
+}
+
+normalize_pkg_arch() {
+	case "${1:-}" in
+	amd64)
+		printf 'x86_64\n'
+		;;
+	*)
+		printf '%s\n' "${1:-}"
+		;;
+	esac
+}
+
+DETECTED_RELEASE=$(detect_release)
+DETECTED_MACHINE_ARCH=$(uname -m)
+
+RELEASE=${DETECTED_RELEASE}
+MACHINE_ARCH=${DETECTED_MACHINE_ARCH}
+NETBSD_MIRROR=
+CELL_BASE_DIR=/var/cellmgr/base
+CELL_DATA_DIR=/var/cellmgr/cells
+CELL_VOLUME_DIR=/var/cellmgr/volumes
+CELL_BACKUP_DIR=/var/backups/cellmgr
+CELL_RELEASE_DIR=/var/cellmgr/releases
+CELLMGR_MANIFEST_DIR=/etc/cellmgr
+PKG_MIRROR=http://cdn.NetBSD.org/pub/pkgsrc/packages/NetBSD
+PKG_ARCH=${DETECTED_MACHINE_ARCH}
+PKG_RELEASE=
+PKG_PATH=
+
+# Per-cell local /dev setup.
+CELL_LOCAL_DEV=YES
+CELL_DEV_SIZE=8m
+CELL_DEVICES="std ptm"
+CELL_PTYFS=YES
+
+if [ -r "${CONF_FILE}" ]; then
+	# shellcheck disable=SC1090
+	. "${CONF_FILE}"
+fi
+
+if [ -z "${RELEASE:-}" ]; then
+	RELEASE=${DETECTED_RELEASE}
+fi
+
+if [ -z "${MACHINE_ARCH:-}" ]; then
+	MACHINE_ARCH=${DETECTED_MACHINE_ARCH}
+fi
+
+if [ -z "${CELLMGR_MANIFEST_DIR:-}" ]; then
+	CELLMGR_MANIFEST_DIR=/etc/cellmgr
+fi
+
+if [ -z "${CELL_VOLUME_DIR:-}" ]; then
+	CELL_VOLUME_DIR=/var/cellmgr/volumes
+fi
+
+if [ -z "${CELL_BACKUP_DIR:-}" ]; then
+	CELL_BACKUP_DIR=/var/backups/cellmgr
+fi
+
+if [ -z "${PKG_MIRROR:-}" ]; then
+	PKG_MIRROR=http://cdn.NetBSD.org/pub/pkgsrc/packages/NetBSD
+fi
+
+if [ -z "${PKG_ARCH:-}" ]; then
+	PKG_ARCH=${MACHINE_ARCH}
+fi
+PKG_ARCH=$(normalize_pkg_arch "${PKG_ARCH}")
+
+if [ -z "${PKG_RELEASE:-}" ]; then
+	PKG_RELEASE=$(normalize_release_major_minor "${RELEASE}")
+fi
+
+if [ -z "${PKG_PATH:-}" ]; then
+	PKG_PATH="${PKG_MIRROR%/}/${PKG_ARCH}/${PKG_RELEASE}/All"
+fi
+
+write_default_conf() {
+	if [ -r "${CONF_FILE}" ]; then
+		return
+	fi
+
+	cat > "${CONF_FILE}" <<CONF
+# autogenerated by cellmgr bootstrap
+
+RELEASE=${RELEASE}
+MACHINE_ARCH=${MACHINE_ARCH}
+
+# Optional override. If unset/empty, cellmgr derives:
+# https://cdn.netbsd.org/pub/NetBSD/NetBSD-\${RELEASE}/
+# \${MACHINE_ARCH}/binary/sets
+NETBSD_MIRROR=""
+
+CELL_BASE_DIR=${CELL_BASE_DIR}
+CELL_DATA_DIR=${CELL_DATA_DIR}
+CELL_VOLUME_DIR=${CELL_VOLUME_DIR}
+CELL_BACKUP_DIR=${CELL_BACKUP_DIR}
+CELL_RELEASE_DIR=${CELL_RELEASE_DIR}
+CELLMGR_MANIFEST_DIR=${CELLMGR_MANIFEST_DIR}
+
+# Package source used by declarative APPLY directives (PKG).
+# PKG_RELEASE is normalized to major.minor without suffixes.
+PKG_MIRROR=${PKG_MIRROR}
+PKG_ARCH=${PKG_ARCH}
+PKG_RELEASE=${PKG_RELEASE}
+PKG_PATH=${PKG_PATH}
+
+# Per-cell local /dev setup (tmpfs + MAKEDEV)
+CELL_LOCAL_DEV=${CELL_LOCAL_DEV}
+CELL_DEV_SIZE=${CELL_DEV_SIZE}
+CELL_DEVICES="${CELL_DEVICES}"
+CELL_PTYFS=${CELL_PTYFS}
+CONF
+
+	echo "Generated ${CONF_FILE} (RELEASE=${RELEASE})"
+}
+
+if [ -z "${NETBSD_MIRROR}" ]; then
+	NETBSD_MIRROR="https://cdn.netbsd.org/pub/NetBSD/NetBSD-${RELEASE}/\
+${MACHINE_ARCH}/binary/sets"
+fi
+
+BASE_LAYER="${CELL_BASE_DIR}/${RELEASE}-${MACHINE_ARCH}"
+SET_DIR="${CELL_RELEASE_DIR}/${RELEASE}/${MACHINE_ARCH}"
+BASE_SET="${SET_DIR}/base.tar.xz"
+ETC_SET="${SET_DIR}/etc.tar.xz"
+XBASE_SET="${SET_DIR}/xbase.tar.xz"
+MANIFEST_DIR="${CELLMGR_MANIFEST_DIR}"
+RECONCILE_VERBOSE=NO
+RECONCILE_SILENT=NO
+RECONCILE_LAST_SECTION=
+RECONCILE_TARGET_NAMES=
+CELLMGR_ASSUME_YES=NO
+
+usage() {
+	cat <<USAGE
+Usage:
+  $0 system <bootstrap|reset> ...
+  $0 ipc serve [--stdio]
+  $0 cell <list|show|fields|create|set|remove|start|stop|restart|shell|plan|edit|backup> ...
+  $0 volume <list|show|fields|create|set|remove|edit|backup> ...
+  $0 apply [--all|<name>...] [--dry-run] [--reapply] [--restart-changed] [--silent|-v]
+  $0 help
+
+IPC:
+  ipc serve [--stdio]
+      Start the message-based stdio control endpoint.
+
+Read output options:
+  --view <merged|desired|runtime>   Select projection view (default: merged)
+  -o <fields>                       Comma-separated field list
+  -T                                Emit TSV
+  -H                                Omit TSV header (requires -T)
+
+Cell commands:
+  cell list [--view ...] [-o fields] [-T] [-H]
+  cell show <name> [--view ...] [-o fields] [-T] [-H]
+  cell fields [--view ...] [-T] [-H]
+  cell create <name> [--autostart YES|NO] --cmd <command>
+      [--profile low|medium|high] [--reserved-ports ports]
+      [--rlimit-nofile n|unlimited] [--rlimit-as bytes|unlimited]
+      [--rlimit-core bytes|unlimited]
+      [--depends-on deps] [--healthcheck cmd] [--mount spec]
+      [--log-facility fac] [--stdout-level lvl] [--stderr-level lvl]
+      [--log-tag tag] [--scope desired|both]
+  cell set <name> [same options as create] [--clear-reserved-ports]
+      [--clear-rlimit-nofile] [--clear-rlimit-as] [--clear-rlimit-core]
+      [--clear-depends-on] [--clear-healthcheck] [--clear-mounts]
+      [--clear-log] [--scope desired|both]
+  cell remove <name|--all|--orphans> [--scope desired|runtime|both] [--yes] [--force]
+  cell start <name|--all> [--scope runtime|both]
+  cell stop <name|--all> [--scope runtime|both]
+  cell restart <name|--all> [--scope runtime|both]
+  cell shell <name>
+  cell plan run <name> [--file path] [--ephemeral]
+  cell edit <name> [--target cell|apply] [--cell|--apply]
+  cell backup create <name>
+  cell backup list <name> [-T] [-H]
+  cell backup restore <name> [--from archive.tar.gz|--latest] [--manifest] [--yes]
+  cell backup delete <name> [--from archive.tar.gz|--latest] [--yes]
+
+Volume commands:
+  volume list [--view ...] [-o fields] [-T] [-H]
+  volume show <name> [--view ...] [-o fields] [-T] [-H]
+  volume fields [--view ...] [-T] [-H]
+  volume create <name> [-m mode] [--scope desired|both]
+  volume set <name> [-m mode] [--scope desired|both]
+  volume remove <name|--all|--orphans> [--scope desired|runtime|both] [--yes]
+  volume edit <name>
+  volume backup create <name>
+  volume backup list <name> [-T] [-H]
+  volume backup restore <name> [--from archive.tar.gz|--latest] [--manifest] [--yes]
+  volume backup delete <name> [--from archive.tar.gz|--latest] [--yes]
+
+System:
+  system bootstrap [--xbase]
+      Download release sets, ensure secmodel_cell, and build shared base layer.
+  system reset [--scope desired|runtime|both] [--cells] [--volumes] [--yes]
+      Reset selected resource sets using destructive --all operations.
+
+Convergence:
+  apply [--all|<name>...] [--dry-run] [--reapply] [--restart-changed] [--silent|-v]
+      Apply desired state by reconciling runtime state.
+      Exit 2 for --dry-run when changes would be required.
+
+Notes:
+  - Default output is human-readable tables.
+  - With -T, output is stable TSV and includes a header unless -H is set.
+  - Destructive --all/--orphans operations require --yes when non-interactive.
+
+Paths:
+  Cell manifests:      ${MANIFEST_DIR}/<name>.cell
+  Apply plans:         ${MANIFEST_DIR}/<name>.apply
+  Volume manifests:    ${MANIFEST_DIR}/<name>.volume
+  Volume backups:      ${CELL_BACKUP_DIR}/volumes/<name>_YYYYmmddHHMMSS.tar.gz
+  Overlay backups:     ${CELL_BACKUP_DIR}/overlays/<name>_YYYYmmddHHMMSS.tar.gz
+  Rendered runtime:    ${CELL_DATA_DIR}/<name>/cell.conf
+  Runtime overlay:     ${CELL_DATA_DIR}/<name>/overlay (mounted as /.overlay)
+USAGE
+}
+
+# Guard helper used by all mutating operations; cell lifecycle changes are
+# intentionally root-only because they manipulate mounts, module state and
+# kernel cell controls.
+need_root() {
+	if [ "$(id -u)" -ne 0 ]; then
+		echo "must be root" >&2
+		exit 1
+	fi
+}
+
+confirm_data_loss() {
+	action=$1
+	if [ "${CELLMGR_ASSUME_YES}" = "YES" ]; then
+		return 0
+	fi
+	if [ ! -r /dev/tty ] || [ ! -w /dev/tty ]; then
+		echo "${action} requires interactive confirmation (no controlling tty)" >&2
+		return 1
+	fi
+	printf 'WARNING: %s\n' "${action}" > /dev/tty
+	printf 'This operation may cause irreversible data loss.\n' > /dev/tty
+	printf 'Type "yes" to continue: ' > /dev/tty
+	IFS= read -r confirm_reply < /dev/tty || return 1
+	if [ "${confirm_reply}" != "yes" ]; then
+		printf 'Aborted.\n' > /dev/tty
+		return 1
+	fi
+	return 0
+}
+
+# Validate external toolchain early so command failures happen before partial
+# state changes (mounts, cell creation, config writes).
+require_tools() {
+	for t in cellctl tar mount mount_tmpfs umount ps; do
+		command -v "${t}" >/dev/null 2>&1 || {
+			echo "missing required tool: ${t}" >&2
+			exit 1
+		}
+	done
+}
+
+ensure_rc_conf_entry() {
+	tmp=
+	if [ ! -f /etc/rc.conf ]; then
+		: > /etc/rc.conf
+	fi
+
+	if grep -Eq '^[[:space:]]*cellmgr=' /etc/rc.conf; then
+		tmp=$(mktemp /tmp/cellmgr-rcconf.XXXXXX)
+		awk '
+			$0 ~ /^[[:space:]]*cellmgr=/ { print "cellmgr=YES"; next }
+			{ print }
+		' /etc/rc.conf > "${tmp}"
+		mv "${tmp}" /etc/rc.conf
+		echo 'Set cellmgr=YES in /etc/rc.conf'
+		return
+	fi
+
+	echo 'cellmgr=YES' >> /etc/rc.conf
+	echo 'Initialized cellmgr=YES in /etc/rc.conf'
+}
+
+escape_dq() {
+	printf '%s' "$1" | sed -e 's/[\\$"`]/\\&/g'
+}
+
+normalize_yesno() {
+	case "${1:-}" in
+	YES|NO)
+		printf '%s\n' "$1"
+		;;
+	"" )
+		printf 'NO\n'
+		;;
+	*)
+		echo "invalid YES/NO value: $1" >&2
+		exit 1
+		;;
+	esac
+}
+
+normalize_dep_list() {
+	printf '%s' "${1:-}" | tr ',' ' '
+}
+
+normalize_volume_mount_list() {
+	printf '%s' "${1:-}" | tr ',' ' '
+}
+
+manifest_cell_paths() {
+	manifest_cell_name=$1
+	MANIFEST_CELL_CONF="${MANIFEST_DIR}/${manifest_cell_name}.cell"
+	MANIFEST_APPLY_FILE="${MANIFEST_DIR}/${manifest_cell_name}.apply"
+}
+
+volume_manifest_paths() {
+	volume_name=$1
+	VOLUME_CONF="${MANIFEST_DIR}/${volume_name}.volume"
+	VOLUME_PATH="${CELL_VOLUME_DIR}/${volume_name}"
+}
+
+volume_manifest_exists() {
+	volume_name=$1
+	volume_manifest_paths "${volume_name}"
+	[ -r "${VOLUME_CONF}" ]
+}
+
+manifest_cell_exists() {
+	manifest_cell_name=$1
+	manifest_cell_paths "${manifest_cell_name}"
+	[ -r "${MANIFEST_CELL_CONF}" ]
+}
+
+assert_valid_cell_name() {
+	cell_name_arg=$1
+	if [ -z "${cell_name_arg}" ]; then
+		echo "cell name cannot be empty" >&2
+		exit 1
+	fi
+	case "${cell_name_arg}" in
+	*[!A-Za-z0-9._-]*)
+		echo "invalid cell name '${cell_name_arg}' (allowed: A-Za-z0-9._-)" >&2
+		exit 1
+		;;
+	esac
+}
+
+assert_valid_volume_name() {
+	volume_name_arg=$1
+	if [ -z "${volume_name_arg}" ]; then
+		echo "volume name cannot be empty" >&2
+		exit 1
+	fi
+	case "${volume_name_arg}" in
+	*[!A-Za-z0-9._-]*)
+		echo "invalid volume name '${volume_name_arg}' (allowed: A-Za-z0-9._-)" >&2
+		exit 1
+		;;
+	esac
+}
+
+ensure_volume_manifest_layout() {
+	layout_mode=${1:-read}
+	if [ "${layout_mode}" = "write" ]; then
+		mkdir -p "${MANIFEST_DIR}" "${CELL_VOLUME_DIR}"
+		return 0
+	fi
+	[ -d "${MANIFEST_DIR}" ]
+}
+
+backup_timestamp() {
+	date +%Y%m%d%H%M%S
+}
+
+backup_subdir_name_for_kind() {
+	case "${1:-}" in
+	volume)
+		printf 'volumes\n'
+		;;
+	overlay)
+		printf 'overlays\n'
+		;;
+	*)
+		echo "invalid backup kind: ${1:-}" >&2
+		return 1
+		;;
+	esac
+}
+
+backup_dir_for_kind() {
+	kind=$1
+	subdir=$(backup_subdir_name_for_kind "${kind}") || return 1
+	printf '%s/%s\n' "${CELL_BACKUP_DIR}" "${subdir}"
+}
+
+backup_search_dirs_for_kind() {
+	kind=$1
+	primary=$(backup_dir_for_kind "${kind}") || return 1
+	printf '%s\n' "${primary}"
+	if [ "${kind}" = "volume" ]; then
+		# Backward compatibility for pre-subdir volume archives.
+		printf '%s\n' "${CELL_BACKUP_DIR}"
+	fi
+}
+
+ensure_backup_layout() {
+	kind=$1
+	layout_mode=${2:-read}
+	backup_dir=$(backup_dir_for_kind "${kind}") || return 1
+	if [ "${layout_mode}" = "write" ]; then
+		mkdir -p "${backup_dir}"
+		return 0
+	fi
+	[ -d "${backup_dir}" ]
+}
+
+resolve_latest_backup_archive() {
+	kind=$1
+	name=$2
+	latest=
+	latest_ts=
+
+	for backup_dir in $(backup_search_dirs_for_kind "${kind}"); do
+		[ -d "${backup_dir}" ] || continue
+		for candidate in "${backup_dir}/${name}_"*.tar.gz; do
+			[ -f "${candidate}" ] || continue
+			base=${candidate##*/}
+			case "${base}" in
+			"${name}_"[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9].tar.gz)
+				timestamp=${base#"${name}_"}
+				timestamp=${timestamp%.tar.gz}
+				if [ -z "${latest}" ] || [ "${timestamp}" \> "${latest_ts}" ]; then
+					latest=${candidate}
+					latest_ts=${timestamp}
+				fi
+				;;
+			esac
+		done
+	done
+
+	if [ -z "${latest}" ]; then
+		echo "no backups found for ${kind} ${name}" >&2
+		return 1
+	fi
+
+	printf '%s\n' "${latest}"
+}
+
+resolve_backup_archive() {
+	kind=$1
+	name=$2
+	archive_arg=${3:-}
+	latest_flag=${4:-NO}
+
+	if [ "${latest_flag}" = "YES" ] || [ -z "${archive_arg}" ]; then
+		resolve_latest_backup_archive "${kind}" "${name}"
+		return $?
+	fi
+
+	if [ -f "${archive_arg}" ] && [ -r "${archive_arg}" ]; then
+		printf '%s\n' "${archive_arg}"
+		return 0
+	fi
+
+	for backup_dir in $(backup_search_dirs_for_kind "${kind}"); do
+		if [ -f "${backup_dir}/${archive_arg}" ] &&
+		    [ -r "${backup_dir}/${archive_arg}" ]; then
+			printf '%s\n' "${backup_dir}/${archive_arg}"
+			return 0
+		fi
+	done
+
+	echo "backup archive not found or unreadable: ${archive_arg}" >&2
+	return 1
+}
+
+resolve_latest_volume_backup_archive() {
+	resolve_latest_backup_archive volume "$1"
+}
+
+resolve_volume_backup_archive() {
+	resolve_backup_archive volume "$1" "${2:-}" "${3:-NO}"
+}
+
+overlay_manifest_path() {
+	name=$1
+	printf '%s/%s.cell\n' "${MANIFEST_DIR}" "${name}"
+}
+
+overlay_apply_path() {
+	name=$1
+	printf '%s/%s.apply\n' "${MANIFEST_DIR}" "${name}"
+}
+
+volume_manifest_path() {
+	name=$1
+	printf '%s/%s.volume\n' "${MANIFEST_DIR}" "${name}"
+}
+
+backup_manifest_snapshot_path() {
+	archive_path=$1
+	snapshot_suffix=${2:-manifest}
+	printf '%s.%s\n' "${archive_path%.tar.gz}" "${snapshot_suffix}"
+}
+
+backup_legacy_manifest_snapshot_path() {
+	archive_path=$1
+	backup_manifest_snapshot_path "${archive_path}" manifest
+}
+
+write_backup_manifest_snapshot() {
+	manifest_src=$1
+	archive_path=$2
+	snapshot_suffix=${3:-manifest}
+	snapshot=$(backup_manifest_snapshot_path "${archive_path}" "${snapshot_suffix}")
+
+	rm -f "${snapshot}"
+	if [ -f "${manifest_src}" ] && [ -r "${manifest_src}" ]; then
+		cp -p "${manifest_src}" "${snapshot}"
+	fi
+}
+
+restore_backup_manifest_snapshot() {
+	snapshot_expected_from_archive=$1
+	manifest_dst=$2
+	snapshot_suffix=${3:-manifest}
+	allow_legacy=${4:-NO}
+	snapshot=$(backup_manifest_snapshot_path "${snapshot_expected_from_archive}" "${snapshot_suffix}")
+
+	if [ ! -f "${snapshot}" ] || [ ! -r "${snapshot}" ]; then
+		if [ "${allow_legacy}" = "YES" ]; then
+			legacy_snapshot=$(backup_legacy_manifest_snapshot_path "${snapshot_expected_from_archive}")
+			if [ -f "${legacy_snapshot}" ] && [ -r "${legacy_snapshot}" ]; then
+				snapshot=${legacy_snapshot}
+			else
+				echo "requested --manifest restore but snapshot is missing: ${snapshot}" >&2
+				return 1
+			fi
+		else
+			echo "requested --manifest restore but snapshot is missing: ${snapshot}" >&2
+			return 1
+		fi
+	fi
+
+	ensure_manifest_layout write
+	cp -p "${snapshot}" "${manifest_dst}"
+	return 0
+}
+
+restore_backup_manifest_snapshot_optional() {
+	snapshot_expected_from_archive=$1
+	manifest_dst=$2
+	snapshot_suffix=$3
+	snapshot=$(backup_manifest_snapshot_path "${snapshot_expected_from_archive}" "${snapshot_suffix}")
+
+	if [ ! -f "${snapshot}" ] || [ ! -r "${snapshot}" ]; then
+		return 0
+	fi
+
+	ensure_manifest_layout write
+	cp -p "${snapshot}" "${manifest_dst}"
+	return 0
+}
+
+clear_directory_contents() {
+	dir_path=$1
+	case "${dir_path}" in
+	""|/)
+		echo "refusing to clear unsafe directory path: ${dir_path}" >&2
+		return 1
+		;;
+	esac
+
+	for entry in "${dir_path}"/.[!.]* "${dir_path}"/..?* "${dir_path}"/*; do
+		[ -e "${entry}" ] || [ -L "${entry}" ] || continue
+		rm -rf "${entry}"
+	done
+
+	return 0
+}
+
+validate_volume_mode() {
+	volume_mode_value=$1
+	[ -n "${volume_mode_value}" ] || return 0
+	case "${volume_mode_value}" in
+	[0-7][0-7][0-7][0-7])
+		return 0
+		;;
+	*)
+		echo "invalid volume mode '${volume_mode_value}' (expected 4-digit octal, e.g. 0755)" >&2
+		return 1
+		;;
+	esac
+}
+
+normalize_volume_mode() {
+	volume_mode_value=${1:-}
+	[ -n "${volume_mode_value}" ] || {
+		printf '\n'
+		return 0
+	}
+
+	while [ "${volume_mode_value#0}" != "${volume_mode_value}" ] &&
+	    [ "${volume_mode_value}" != "0" ]; do
+		volume_mode_value=${volume_mode_value#0}
+	done
+
+	printf '%s\n' "${volume_mode_value}"
+}
+
+parse_volume_mount_spec() {
+	spec=$1
+	spec_ctx=$2
+
+	set -f
+	old_ifs=${IFS}
+	IFS=:
+	set -- ${spec}
+	IFS=${old_ifs}
+	set +f
+
+	if [ $# -eq 2 ]; then
+		MOUNT_VOLUME=$1
+		MOUNT_TARGET=$2
+		MOUNT_MODE=rw
+	elif [ $# -eq 3 ]; then
+		MOUNT_VOLUME=$1
+		MOUNT_TARGET=$2
+		MOUNT_MODE=$3
+	else
+		echo "${spec_ctx}: invalid CELL_VOLUME_MOUNTS entry: ${spec}" >&2
+		return 1
+	fi
+
+	assert_valid_volume_name "${MOUNT_VOLUME}"
+	case "${MOUNT_TARGET}" in
+	/*)
+		;;
+	*)
+		echo "${spec_ctx}: mount target must be absolute: ${MOUNT_TARGET}" >&2
+		return 1
+		;;
+	esac
+	case "${MOUNT_TARGET}" in
+	/|/dev|/dev/*|/.overlay|/.overlay/*)
+		echo "${spec_ctx}: mount target is not allowed: ${MOUNT_TARGET}" >&2
+		return 1
+		;;
+	esac
+	case "${MOUNT_MODE}" in
+	ro|rw)
+		;;
+	*)
+		echo "${spec_ctx}: mount mode must be ro or rw: ${MOUNT_MODE}" >&2
+		return 1
+		;;
+	esac
+
+	return 0
+}
+
+path_is_same_or_child() {
+	child=$1
+	parent=$2
+	if [ "${child}" = "${parent}" ]; then
+		return 0
+	fi
+	case "${child}" in
+	"${parent}"/*)
+		return 0
+		;;
+	esac
+	return 1
+}
+
+validate_cell_volume_mounts() {
+	mount_list=$1
+	origin=$2
+	require_volume_manifest=${3:-NO}
+
+	CELL_VOLUME_MOUNTS_NORMALIZED=
+	seen_targets=
+
+	for spec in $(normalize_volume_mount_list "${mount_list}"); do
+		parse_volume_mount_spec "${spec}" "${origin}" || return 1
+
+		if [ "${require_volume_manifest}" = "YES" ]; then
+			if ! volume_manifest_exists "${MOUNT_VOLUME}"; then
+				echo "${origin}: referenced volume not found: ${MOUNT_VOLUME}" >&2
+				return 1
+			fi
+		fi
+
+		for existing_target in ${seen_targets}; do
+			if path_is_same_or_child "${MOUNT_TARGET}" "${existing_target}" ||
+			   path_is_same_or_child "${existing_target}" "${MOUNT_TARGET}"; then
+				echo "${origin}: overlapping mount targets are not allowed: ${MOUNT_TARGET} and ${existing_target}" >&2
+				return 1
+			fi
+		done
+		seen_targets="${seen_targets} ${MOUNT_TARGET}"
+
+		if [ -n "${CELL_VOLUME_MOUNTS_NORMALIZED}" ]; then
+			CELL_VOLUME_MOUNTS_NORMALIZED="${CELL_VOLUME_MOUNTS_NORMALIZED},"
+		fi
+		CELL_VOLUME_MOUNTS_NORMALIZED="${CELL_VOLUME_MOUNTS_NORMALIZED}${MOUNT_VOLUME}:${MOUNT_TARGET}:${MOUNT_MODE}"
+	done
+
+	return 0
+}
+
+ensure_manifest_layout() {
+	layout_mode=${1:-read}
+	if [ "${layout_mode}" = "write" ]; then
+		mkdir -p "${MANIFEST_DIR}"
+		return 0
+	fi
+	[ -d "${MANIFEST_DIR}" ]
+}
+
+load_volume_manifest_conf() {
+	volume_name=$1
+	volume_manifest_paths "${volume_name}"
+	if [ ! -r "${VOLUME_CONF}" ]; then
+		echo "missing volume manifest ${VOLUME_CONF}" >&2
+		exit 1
+	fi
+
+	VOLUME_NAME=
+	VOLUME_MODE=
+	# shellcheck disable=SC1090
+	. "${VOLUME_CONF}"
+
+	if [ -z "${VOLUME_NAME:-}" ]; then
+		VOLUME_NAME=${volume_name}
+	fi
+	if [ "${VOLUME_NAME}" != "${volume_name}" ]; then
+		echo "volume manifest mismatch: expected VOLUME_NAME=${volume_name}, got ${VOLUME_NAME}" >&2
+		exit 1
+	fi
+	assert_valid_volume_name "${VOLUME_NAME}"
+	validate_volume_mode "${VOLUME_MODE:-}" || exit 1
+}
+
+ensure_volume_runtime_from_manifest() {
+	volume_name=$1
+	load_volume_manifest_conf "${volume_name}"
+	volume_manifest_paths "${volume_name}"
+
+	mkdir -p "${CELL_VOLUME_DIR}" "${VOLUME_PATH}"
+	if [ -n "${VOLUME_MODE:-}" ]; then
+		chmod "${VOLUME_MODE}" "${VOLUME_PATH}"
+	fi
+}
+
+reconcile_volumes() {
+	dry_run=$1
+	changed=0
+
+	if ! ensure_volume_manifest_layout; then
+		return 0
+	fi
+
+	for volume_conf in "${MANIFEST_DIR}"/*.volume; do
+		[ -f "${volume_conf}" ] || continue
+		name=${volume_conf##*/}
+		name=${name%.volume}
+		volume_changed=0
+		assert_valid_volume_name "${name}"
+		load_volume_manifest_conf "${name}"
+		volume_manifest_paths "${name}"
+
+		if [ ! -d "${VOLUME_PATH}" ]; then
+			emit_reconcile_section_action "volumes" "VOLUME" \
+			    "create ${name} (${VOLUME_PATH})"
+			changed=1
+			volume_changed=1
+		elif [ -n "${VOLUME_MODE:-}" ]; then
+			runtime_mode_raw=$(stat -f %Lp "${VOLUME_PATH}" 2>/dev/null || true)
+			runtime_mode=$(normalize_volume_mode "${runtime_mode_raw}")
+			desired_mode=$(normalize_volume_mode "${VOLUME_MODE}")
+			if [ -n "${runtime_mode}" ] && [ "${runtime_mode}" != "${desired_mode}" ]; then
+				emit_reconcile_section_action "volumes" "VOLUME" \
+				    "chmod ${name} (${VOLUME_PATH}) ${runtime_mode} -> ${VOLUME_MODE}"
+				changed=1
+				volume_changed=1
+			fi
+		fi
+		if [ "${volume_changed}" -eq 0 ]; then
+			emit_reconcile_section_action "volumes" "NOOP" "${name} already converged"
+		fi
+		if [ "${dry_run}" = "NO" ]; then
+			ensure_volume_runtime_from_manifest "${name}"
+		fi
+	done
+
+	if [ "${changed}" -ne 0 ]; then
+		return 2
+	fi
+	return 0
+}
+
+create_manifest_volume() {
+	need_root
+	name=$1
+	volume_mode_arg=${2:-}
+
+	assert_valid_volume_name "${name}"
+	validate_volume_mode "${volume_mode_arg}" || exit 1
+
+	ensure_volume_manifest_layout write
+	volume_manifest_paths "${name}"
+	if [ -e "${VOLUME_CONF}" ]; then
+		echo "volume manifest already exists: ${VOLUME_CONF}" >&2
+		exit 1
+	fi
+
+	escaped_mode=$(escape_dq "${volume_mode_arg}")
+
+	cat > "${VOLUME_CONF}" <<CONF
+# declarative volume manifest for cellmgr
+VOLUME_NAME=${name}
+VOLUME_MODE="${escaped_mode}"
+CONF
+
+	echo "Created manifest volume ${name}"
+}
+
+set_manifest_volume() {
+	need_root
+	name=$1
+	volume_mode_arg=${2:-}
+
+	assert_valid_volume_name "${name}"
+	validate_volume_mode "${volume_mode_arg}" || exit 1
+	ensure_volume_manifest_layout write
+	volume_manifest_paths "${name}"
+	if [ ! -f "${VOLUME_CONF}" ]; then
+		echo "manifest volume not found: ${name}" >&2
+		exit 1
+	fi
+
+	escaped_mode=$(escape_dq "${volume_mode_arg}")
+	cat > "${VOLUME_CONF}" <<CONF
+# declarative volume manifest for cellmgr
+VOLUME_NAME=${name}
+VOLUME_MODE="${escaped_mode}"
+CONF
+	echo "Updated manifest volume ${name}"
+}
+
+volume_ref_count() {
+	volume_name=$1
+	count=0
+
+	if ensure_manifest_layout; then
+		for cell_conf in "${MANIFEST_DIR}"/*.cell; do
+			[ -f "${cell_conf}" ] || continue
+			CELL_VOLUME_MOUNTS=
+			# shellcheck disable=SC1090
+			. "${cell_conf}"
+
+			for spec in $(normalize_volume_mount_list "${CELL_VOLUME_MOUNTS:-}"); do
+				if ! parse_volume_mount_spec "${spec}" "volume_ref_count"; then
+					continue
+				fi
+				if [ "${MOUNT_VOLUME}" = "${volume_name}" ]; then
+					count=$((count + 1))
+					break
+				fi
+			done
+		done
+	fi
+
+	printf '%s\n' "${count}"
+}
+
+remove_manifest_volume() {
+	need_root
+	name=$1
+	assert_valid_volume_name "${name}"
+	volume_manifest_paths "${name}"
+
+	if [ ! -f "${VOLUME_CONF}" ]; then
+		echo "manifest volume not found: ${name}" >&2
+		exit 1
+	fi
+
+	refs=$(volume_ref_count "${name}")
+	if [ "${refs}" -gt 0 ]; then
+		echo "cannot remove volume ${name}: still referenced by ${refs} cell manifest(s)" >&2
+		exit 1
+	fi
+
+	rm -f "${VOLUME_CONF}"
+	echo "Removed manifest volume ${name}"
+}
+
+remove_manifest_volumes_all() {
+	need_root
+	names=
+	if ensure_volume_manifest_layout; then
+		for volume_conf in "${MANIFEST_DIR}"/*.volume; do
+			[ -f "${volume_conf}" ] || continue
+			name=${volume_conf##*/}
+			name=${name%.volume}
+			names="${names} ${name}"
+		done
+	fi
+	set -- ${names}
+	if [ $# -eq 0 ]; then
+		echo "No manifest volumes found to remove"
+		return
+	fi
+	if ! confirm_data_loss "Removing all manifest volume definitions from ${MANIFEST_DIR}"; then
+		exit 1
+	fi
+	removed=0
+	for name in "$@"; do
+		remove_manifest_volume "${name}"
+		removed=$((removed + 1))
+	done
+	echo "Removed ${removed} manifest volumes"
+}
+
+runtime_volume_mounted() {
+	volume_path=$1
+	mount | awk -v p="${volume_path} on " 'index($0,p){found=1} END{exit !found}'
+}
+
+prune_runtime_volume() {
+	need_root
+	name=$1
+	assert_valid_volume_name "${name}"
+	volume_manifest_paths "${name}"
+
+	if [ ! -d "${VOLUME_PATH}" ]; then
+		echo "runtime volume not found: ${name}" >&2
+		exit 1
+	fi
+
+	if runtime_volume_mounted "${VOLUME_PATH}"; then
+		echo "cannot remove runtime volume ${name}: currently mounted" >&2
+		exit 1
+	fi
+
+	rm -rf "${VOLUME_PATH}"
+	echo "Removed runtime volume ${name}"
+}
+
+prune_runtime_volumes() {
+	need_root
+	mode=${1:-all}
+
+	case "${mode}" in
+	all|orphans)
+		;;
+	*)
+		echo "invalid runtime volume prune mode: ${mode}" >&2
+		exit 1
+		;;
+	esac
+
+	names=
+	if [ -d "${CELL_VOLUME_DIR}" ]; then
+		for volume_path in "${CELL_VOLUME_DIR}"/*; do
+			[ -d "${volume_path}" ] || continue
+			name=${volume_path##*/}
+			case "${name}" in
+			*[!A-Za-z0-9._-]*)
+				echo "Skipping invalid runtime volume directory ${volume_path}" >&2
+				continue
+				;;
+			esac
+			if [ "${mode}" = "orphans" ]; then
+				volume_manifest_paths "${name}"
+				if [ -f "${VOLUME_CONF}" ]; then
+					continue
+				fi
+			fi
+			names="${names} ${name}"
+		done
+	fi
+
+	set -- ${names}
+	if [ $# -eq 0 ]; then
+		if [ "${mode}" = "orphans" ]; then
+			echo "No orphan runtime volumes found to prune"
+		else
+			echo "No runtime volumes found to prune"
+		fi
+		return
+	fi
+
+	if [ "${mode}" = "orphans" ]; then
+		if ! confirm_data_loss "Pruning orphan runtime volumes under ${CELL_VOLUME_DIR}"; then
+			exit 1
+		fi
+	else
+		if ! confirm_data_loss "Pruning all runtime volumes under ${CELL_VOLUME_DIR}"; then
+			exit 1
+		fi
+	fi
+
+	pruned=0
+	for name in "$@"; do
+		prune_runtime_volume "${name}"
+		pruned=$((pruned + 1))
+	done
+
+	if [ "${mode}" = "orphans" ]; then
+		echo "Pruned ${pruned} orphan runtime volumes"
+		return
+	fi
+	echo "Pruned ${pruned} runtime volumes"
+}
+
+backup_volume() {
+	need_root
+	name=$1
+	assert_valid_volume_name "${name}"
+	volume_manifest_paths "${name}"
+
+	if [ ! -d "${VOLUME_PATH}" ]; then
+		echo "runtime volume not found: ${name}" >&2
+		exit 1
+	fi
+
+	ensure_backup_layout volume write
+	backup_dir=$(backup_dir_for_kind volume)
+	timestamp=$(backup_timestamp)
+	archive_path="${backup_dir}/${name}_${timestamp}.tar.gz"
+	if [ -e "${archive_path}" ]; then
+		echo "backup archive already exists: ${archive_path}" >&2
+		exit 1
+	fi
+
+	if ! tar -czpf "${archive_path}" -C "${VOLUME_PATH}" .; then
+		rm -f "${archive_path}" >/dev/null 2>&1 || true
+		echo "failed to create backup archive: ${archive_path}" >&2
+		exit 1
+	fi
+	write_backup_manifest_snapshot "$(volume_manifest_path "${name}")" "${archive_path}" volume
+
+	echo "Created volume backup ${archive_path}"
+}
+
+list_volume_backups() {
+	name=$1
+	tsv=${2:-NO}
+	header=${3:-YES}
+	assert_valid_volume_name "${name}"
+
+	raw_tmp=$(mktemp /tmp/cellmgr-volume-backups.XXXXXX)
+	sorted_tmp=$(mktemp /tmp/cellmgr-volume-backups-sorted.XXXXXX)
+	: > "${raw_tmp}"
+
+	for backup_dir in $(backup_search_dirs_for_kind volume); do
+		[ -d "${backup_dir}" ] || continue
+		for candidate in "${backup_dir}/${name}_"*.tar.gz; do
+			[ -f "${candidate}" ] || continue
+			base=${candidate##*/}
+			case "${base}" in
+			"${name}_"[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9].tar.gz)
+				timestamp=${base#"${name}_"}
+				timestamp=${timestamp%.tar.gz}
+				size=$(wc -c < "${candidate}" | tr -d '[:space:]')
+				printf '%s\t%s\t%s\t%s\n' "${name}" "${timestamp}" "${size}" "${candidate}" >> "${raw_tmp}"
+				;;
+			esac
+		done
+	done
+
+	LC_ALL=C sort -r -k2,2 "${raw_tmp}" > "${sorted_tmp}"
+
+	if [ "${tsv}" = "YES" ]; then
+		if [ "${header}" = "YES" ]; then
+			printf 'volume\ttimestamp\tsize\tarchive\n'
+		fi
+		cat "${sorted_tmp}"
+	else
+		printf '%-24s %-14s %-12s %s\n' 'VOLUME' 'TIMESTAMP' 'SIZE' 'ARCHIVE'
+		awk -F '\t' '{ printf "%-24s %-14s %-12s %s\n", $1, $2, $3, $4 }' "${sorted_tmp}"
+	fi
+
+	rm -f "${raw_tmp}" "${sorted_tmp}"
+}
+
+restore_volume() {
+	need_root
+	name=$1
+	archive_arg=${2:-}
+	latest_flag=${3:-NO}
+	restore_manifest=${4:-NO}
+
+	assert_valid_volume_name "${name}"
+	if [ "${latest_flag}" = "YES" ] && [ -n "${archive_arg}" ]; then
+		echo "volume restore: --latest cannot be combined with explicit archive path" >&2
+		exit 1
+	fi
+
+	archive_path=$(resolve_volume_backup_archive "${name}" "${archive_arg}" "${latest_flag}") || exit 1
+	volume_manifest_paths "${name}"
+
+	if [ -d "${VOLUME_PATH}" ] && runtime_volume_mounted "${VOLUME_PATH}"; then
+		echo "cannot restore runtime volume ${name}: currently mounted" >&2
+		exit 1
+	fi
+
+	if [ ! -d "${VOLUME_PATH}" ]; then
+		if volume_manifest_exists "${name}"; then
+			ensure_volume_runtime_from_manifest "${name}"
+		else
+			mkdir -p "${CELL_VOLUME_DIR}" "${VOLUME_PATH}"
+		fi
+	fi
+
+	if [ "${VOLUME_PATH}" = "${CELL_VOLUME_DIR}" ] ||
+	    ! path_is_same_or_child "${VOLUME_PATH}" "${CELL_VOLUME_DIR}"; then
+		echo "refusing to restore into unsafe volume path: ${VOLUME_PATH}" >&2
+		exit 1
+	fi
+
+	if ! confirm_data_loss "Restoring volume ${name} from ${archive_path} into ${VOLUME_PATH}"; then
+		exit 1
+	fi
+
+	restore_tmp=$(mktemp -d /tmp/cellmgr-volume-restore.XXXXXX)
+	if ! tar -xzpf "${archive_path}" -C "${restore_tmp}"; then
+		rm -rf "${restore_tmp}" >/dev/null 2>&1 || true
+		echo "failed to extract backup archive: ${archive_path}" >&2
+		exit 1
+	fi
+
+	if ! clear_directory_contents "${VOLUME_PATH}"; then
+		rm -rf "${restore_tmp}" >/dev/null 2>&1 || true
+		exit 1
+	fi
+	if ! cp -Rp "${restore_tmp}/." "${VOLUME_PATH}"; then
+		rm -rf "${restore_tmp}" >/dev/null 2>&1 || true
+		echo "failed to restore backup contents into ${VOLUME_PATH}" >&2
+		exit 1
+	fi
+	rm -rf "${restore_tmp}" >/dev/null 2>&1 || true
+
+	if [ "${restore_manifest}" = "YES" ]; then
+		if ! restore_backup_manifest_snapshot "${archive_path}" "$(volume_manifest_path "${name}")" volume YES; then
+			exit 1
+		fi
+	fi
+
+	echo "Restored volume ${name} from ${archive_path}"
+}
+
+delete_volume_backup() {
+	need_root
+	name=$1
+	archive_arg=${2:-}
+	latest_flag=${3:-NO}
+
+	assert_valid_volume_name "${name}"
+	if [ "${latest_flag}" = "YES" ] && [ -n "${archive_arg}" ]; then
+		echo "volume backup delete: --latest cannot be combined with explicit archive path" >&2
+		exit 1
+	fi
+
+	archive_path=$(resolve_volume_backup_archive "${name}" "${archive_arg}" "${latest_flag}") || exit 1
+	archive_base=${archive_path##*/}
+	case "${archive_base}" in
+	"${name}_"[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9].tar.gz)
+		;;
+	*)
+		echo "refusing to delete archive that does not match volume backup naming: ${archive_path}" >&2
+		exit 1
+		;;
+	esac
+
+	archive_allowed=NO
+	for backup_dir in $(backup_search_dirs_for_kind volume); do
+		if [ "${archive_path}" != "${backup_dir}" ] &&
+		    path_is_same_or_child "${archive_path}" "${backup_dir}"; then
+			archive_allowed=YES
+			break
+		fi
+	done
+	if [ "${archive_allowed}" != "YES" ]; then
+		echo "refusing to delete backup outside allowed volume backup dirs: ${archive_path}" >&2
+		exit 1
+	fi
+
+	if ! confirm_data_loss "Deleting volume backup ${archive_path}"; then
+		exit 1
+	fi
+
+	if ! rm -f -- "${archive_path}"; then
+		echo "failed to delete backup archive: ${archive_path}" >&2
+		exit 1
+	fi
+	rm -f -- "$(backup_manifest_snapshot_path "${archive_path}" volume)" >/dev/null 2>&1 || true
+	rm -f -- "$(backup_legacy_manifest_snapshot_path "${archive_path}")" >/dev/null 2>&1 || true
+
+	echo "Deleted volume backup ${archive_path}"
+}
