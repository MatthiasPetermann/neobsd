+runtime_project_fields() {
+	in_file=$1
+	awk -F '\t' -v cols="${RUNTIME_OUTPUT_CUT}" '
+		BEGIN {
+			OFS="\t"
+			n = split(cols, idx, ",")
+		}
+		{
+			for (i = 1; i <= n; i++) {
+				field_no = idx[i] + 0
+				value = ""
+				if (field_no >= 1 && field_no <= NF) {
+					value = $(field_no)
+				}
+				if (i == 1) {
+					out = value
+				} else {
+					out = out OFS value
+				}
+			}
+			print out
+		}
+	' "${in_file}"
+}
