+fetch_sets() {
+	include_xbase=${1:-NO}
+
+	need_root
+	require_tools
+	mkdir -p "${SET_DIR}"
+
+	fetch_url="${NETBSD_MIRROR%/}"
+
+	if command -v ftp >/dev/null 2>&1; then
+		ftp -V -o "${BASE_SET}" "${fetch_url}/base.tar.xz"
+		ftp -V -o "${ETC_SET}" "${fetch_url}/etc.tar.xz"
+		if [ "${include_xbase}" = "YES" ]; then
+			ftp -V -o "${XBASE_SET}" "${fetch_url}/xbase.tar.xz"
+		fi
+	elif command -v curl >/dev/null 2>&1; then
+		curl -fL -o "${BASE_SET}" "${fetch_url}/base.tar.xz"
+		curl -fL -o "${ETC_SET}" "${fetch_url}/etc.tar.xz"
+		if [ "${include_xbase}" = "YES" ]; then
+			curl -fL -o "${XBASE_SET}" "${fetch_url}/xbase.tar.xz"
+		fi
+	else
+		echo "need ftp(1) or curl to fetch sets" >&2
+		exit 1
+	fi
+
+	echo "Downloaded sets to ${SET_DIR}"
+}
