+		echo "manifest cell not found: ${name}" >&2
+		exit 1
+	fi
+	if [ -z "${supervise_cmd}" ]; then
+		echo "cell set: --cmd cannot be empty" >&2
+		exit 1
+	fi
+	for dep in $(normalize_dep_list "${depends_on}"); do
+		assert_valid_cell_name "${dep}"
+		if [ "${dep}" = "${name}" ]; then
+			echo "cell ${name} cannot depend on itself" >&2
+			exit 1
+		fi
+	done
+	if ! validate_cell_volume_mounts "${volume_mounts}" "set ${name}" NO; then
+		exit 1
+	fi
