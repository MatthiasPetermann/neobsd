+# Ensure the kernel cell security model is available now and across reboot.
+# This is the integration point between cellmgr automation and secmodel_cell.
+ensure_secmodel_cell() {
+	need_root
+
+	if ! modstat | awk '
+		$0 ~ /(^|[[:space:]])secmodel_cell([[:space:]]|$)/ { found=1 }
+		END { exit !found }
+	'; then
+		modload secmodel_cell
+		echo "Loaded secmodel_cell module"
+	fi
+
+	if [ ! -f /etc/modules.conf ]; then
+		: > /etc/modules.conf
+	fi
+
+	if ! grep -Eq '^[[:space:]]*secmodel_cell([[:space:]]|$)' \
+	    /etc/modules.conf; then
+		echo "secmodel_cell" >> /etc/modules.conf
+		echo "Added secmodel_cell to /etc/modules.conf"
+	fi
+}
+
+ensure_base_writable_links() {
+# Writable cell paths live below /.overlay (mounted per-cell). Keep these
+# links in the shared read-only base so every cell sees the same layout.
+	if [ ! -d "${BASE_LAYER}" ]; then
+		echo "missing ${BASE_LAYER}; run bootstrap first" >&2
+		exit 1
+	fi
+
+	mkdir -p "${BASE_LAYER}/.overlay" "${BASE_LAYER}/usr"
+	rm -rf "${BASE_LAYER}/.data"
+	rm -rf "${BASE_LAYER}/etc" "${BASE_LAYER}/var" "${BASE_LAYER}/tmp" \
+		"${BASE_LAYER}/home" "${BASE_LAYER}/root" "${BASE_LAYER}/usr/pkg" \
+		"${BASE_LAYER}/.cshrc" "${BASE_LAYER}/.profile"
+	ln -s ".overlay/etc" "${BASE_LAYER}/etc"
+	ln -s ".overlay/var" "${BASE_LAYER}/var"
+	ln -s ".overlay/tmp" "${BASE_LAYER}/tmp"
+	ln -s ".overlay/home" "${BASE_LAYER}/home"
+	ln -s ".overlay/root" "${BASE_LAYER}/root"
+	ln -s ".overlay/.cshrc" "${BASE_LAYER}/.cshrc"
+	ln -s ".overlay/.profile" "${BASE_LAYER}/.profile"
+	ln -s "../.overlay/usr/pkg" "${BASE_LAYER}/usr/pkg"
+}
+
+
+build_base() {
+	include_xbase=${1:-NO}
+
+	need_root
+	require_tools
+	[ -f "${BASE_SET}" ] || {
+		echo "missing ${BASE_SET}; run bootstrap first" >&2
+		exit 1
+	}
+	if [ "${include_xbase}" = "YES" ]; then
+		[ -f "${XBASE_SET}" ] || {
+			echo "missing ${XBASE_SET}; run bootstrap -x first" >&2
+			exit 1
+		}
+	fi
+
+	mkdir -p "${BASE_LAYER}"
+	tar -xzp -f "${BASE_SET}" -C "${BASE_LAYER}"
+	if [ "${include_xbase}" = "YES" ]; then
+		tar -xzp -f "${XBASE_SET}" -C "${BASE_LAYER}"
+	fi
+	ensure_base_writable_links
+	echo "Prepared base layer at ${BASE_LAYER}"
