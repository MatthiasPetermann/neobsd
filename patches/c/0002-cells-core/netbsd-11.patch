diff --git a/usr.sbin/cellmgr/examples/api-gateway/api-gateway-edge-nginx.apply b/usr.sbin/cellmgr/examples/api-gateway/api-gateway-edge-nginx.apply
new file mode 100644
index 000000000000..ac334c4513ca
--- /dev/null
+++ b/usr.sbin/cellmgr/examples/api-gateway/api-gateway-edge-nginx.apply
@@ -0,0 +1,51 @@
+PKG nginx
+FILE_BEGIN /usr/pkg/etc/nginx/nginx.conf mode=0644
+worker_processes 1;
+daemon off;
+events { worker_connections 1024; }
+error_log /dev/stderr notice;
+pid /tmp/nginx.pid;
+http {
+  include /usr/pkg/etc/nginx/mime.types;
+  default_type application/octet-stream;
+  access_log /dev/stdout combined;
+  sendfile on;
+
+  server {
+    listen 80;
+    server_name _;
+
+    location = / {
+      return 302 /a/;
+    }
+    location = /a {
+      return 301 /a/;
+    }
+    location = /b {
+      return 301 /b/;
+    }
+    location = /c {
+      return 301 /c/;
+    }
+
+    location /a/ {
+      proxy_pass http://127.0.0.1:8080/;
+      proxy_set_header Host $host;
+      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
+      proxy_set_header X-Forwarded-Proto $scheme;
+    }
+    location /b/ {
+      proxy_pass http://127.0.0.1:8081/;
+      proxy_set_header Host $host;
+      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
+      proxy_set_header X-Forwarded-Proto $scheme;
+    }
+    location /c/ {
+      proxy_pass http://127.0.0.1:8082/;
+      proxy_set_header Host $host;
+      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
+      proxy_set_header X-Forwarded-Proto $scheme;
+    }
+  }
+}
+FILE_END
