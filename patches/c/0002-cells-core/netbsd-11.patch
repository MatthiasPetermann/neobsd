+
+cell_paths() {
+	name=$1
+	CELL_DIR="${CELL_DATA_DIR}/${name}"
+	ROOT_DIR="${CELL_DIR}/root"
+	OVERLAY_DIR="${CELL_DIR}/overlay"
+	DATA_ETC_DIR="${OVERLAY_DIR}/etc"
+	DATA_VAR_DIR="${OVERLAY_DIR}/var"
+	DATA_TMP_DIR="${OVERLAY_DIR}/tmp"
+	DATA_HOME_DIR="${OVERLAY_DIR}/home"
+	DATA_ROOT_DIR="${OVERLAY_DIR}/root"
+	DATA_PKG_DIR="${OVERLAY_DIR}/usr/pkg"
+	STATE_DIR="${CELL_DIR}/state"
+	CELL_CONF="${CELL_DIR}/cell.conf"
+}
+
+load_cell_conf() {
+	name=$1
+	cell_paths "${name}"
+	if [ ! -r "${CELL_CONF}" ]; then
+		echo "missing ${CELL_CONF}; run apply first" >&2
+		exit 1
+	fi
+
+	CELL_NAME=
+	CELL_SUPERVISE_CMD=
+	CELL_CREATE_PROFILE=
+	CELL_CREATE_RESERVED_PORTS=
+	CELL_CREATE_RLIMIT_NOFILE=
+	CELL_CREATE_RLIMIT_AS=
+	CELL_CREATE_RLIMIT_CORE=
+	CELL_SUPERVISE_FACILITY=
+	CELL_SUPERVISE_STDOUT_LEVEL=
+	CELL_SUPERVISE_STDERR_LEVEL=
+	CELL_SUPERVISE_TAG=
+	CELL_AUTOSTART=NO
+	CELL_DEPENDS_ON=
+	CELL_HEALTHCHECK_CMD=
+	CELL_VOLUME_MOUNTS=
+	# shellcheck disable=SC1090
+	. "${CELL_CONF}"
+
+	if [ -z "${CELL_NAME:-}" ]; then
+		CELL_NAME=${name}
+	fi
+	if [ "${CELL_NAME}" != "${name}" ]; then
+		echo "cell.conf mismatch: expected CELL_NAME=${name}, got ${CELL_NAME}" >&2
+		exit 1
+	fi
+	if ! validate_cell_volume_mounts "${CELL_VOLUME_MOUNTS:-}" "cell.conf ${CELL_CONF}" NO; then
+		exit 1
+	fi
+	CELL_VOLUME_MOUNTS=${CELL_VOLUME_MOUNTS_NORMALIZED}
+}
+
+# Build per-cell /dev view backed by tmpfs (+ optional ptyfs).  This keeps
+# device nodes scoped to the cell filesystem instead of bind-sharing host /dev.
+setup_local_dev() {
+	if [ "${CELL_LOCAL_DEV}" != "YES" ]; then
+		return
+	fi
+
+	mkdir -p "${ROOT_DIR}/dev"
+	if ! mount | awk -v p="on ${ROOT_DIR}/dev " \
+	    'index($0,p){found=1} END{exit !found}'; then
+		mount_tmpfs -s "${CELL_DEV_SIZE}" tmpfs "${ROOT_DIR}/dev"
+	fi
+
+	if [ ! -f "${ROOT_DIR}/dev/MAKEDEV" ]; then
+		[ -f "${ETC_SET}" ] || {
+			echo "warning: ${ETC_SET} not found; skipping /dev node creation" >&2
+			return
+		}
+
+		tar -xzp -f "${ETC_SET}" -C "${ROOT_DIR}" ./dev/MAKEDEV
+		chmod 555 "${ROOT_DIR}/dev/MAKEDEV"
+		if tar -tzp -f "${ETC_SET}" ./dev/MAKEDEV.local >/dev/null 2>&1; then
+			tar -xzp -f "${ETC_SET}" -C "${ROOT_DIR}" ./dev/MAKEDEV.local
+			chmod 444 "${ROOT_DIR}/dev/MAKEDEV.local"
+		fi
+	fi
+
+	# shellcheck disable=SC2086
+	(cd "${ROOT_DIR}/dev" && sh ./MAKEDEV ${CELL_DEVICES})
+
+	if [ "${CELL_PTYFS}" = "YES" ]; then
+		mkdir -p "${ROOT_DIR}/dev/pts"
+		if ! mount | awk -v p="on ${ROOT_DIR}/dev/pts " \
+		    'index($0,p){found=1} END{exit !found}'; then
+			mount -t ptyfs ptyfs "${ROOT_DIR}/dev/pts"
+		fi
+	fi
+}
+
+setup_etc() {
+	[ -f "${ETC_SET}" ] || {
+		echo "missing ${ETC_SET}; run bootstrap first" >&2
+		exit 1
+	}
+
+	if [ ! -f "${DATA_ETC_DIR}/rc.conf" ]; then
+		# etc.tar.xz stores root dotfiles as hardlinks to ./.cshrc/.profile.
+		# Extract those link targets too so tar does not abort with missing
+		# hard-link target errors while unpacking ./root.
+		tar -xzp -f "${ETC_SET}" -C "${OVERLAY_DIR}" \
+			./.cshrc ./.profile ./etc ./root ./var
+	fi
+
+	# Keep cell DNS and timezone defaults aligned with the host at create time.
+	# This provides working name resolution and expected local time.
+	if [ -f /etc/resolv.conf ]; then
+		cp /etc/resolv.conf "${DATA_ETC_DIR}/resolv.conf"
+	fi
+	if [ -e /etc/localtime ] || [ -L /etc/localtime ]; then
+		cp -P /etc/localtime "${DATA_ETC_DIR}/localtime" 2>/dev/null ||
+		    cp /etc/localtime "${DATA_ETC_DIR}/localtime"
+	fi
+
+	grep -q '^hostname=' "${DATA_ETC_DIR}/rc.conf" 2>/dev/null ||
+		echo "hostname=${name}" >> "${DATA_ETC_DIR}/rc.conf"
+}
+
+mount_cell_volumes() {
+	mount_specs=${CELL_VOLUME_MOUNTS:-}
+	[ -n "${mount_specs}" ] || return 0
+	mounted_targets=
+
+	for spec in $(normalize_volume_mount_list "${mount_specs}"); do
+		parse_volume_mount_spec "${spec}" "CELL_VOLUME_MOUNTS" || return 1
+		if ! volume_manifest_exists "${MOUNT_VOLUME}"; then
+			echo "missing referenced volume manifest: ${MOUNT_VOLUME}" >&2
+			return 1
+		fi
+		if ! ensure_volume_runtime_from_manifest "${MOUNT_VOLUME}"; then
+			for rollback_target in ${mounted_targets}; do
+				rmpt="${ROOT_DIR}${rollback_target}"
+				umount "${rmpt}" >/dev/null 2>&1 || true
+			done
+			return 1
+		fi
+		volume_manifest_paths "${MOUNT_VOLUME}"
+
+		target_mount_point="${ROOT_DIR}${MOUNT_TARGET}"
+		mkdir -p "${target_mount_point}"
+		if mount | awk -v p="on ${target_mount_point} " 'index($0,p){found=1} END{exit !found}'; then
+			if ! mount | awk -v p="${VOLUME_PATH} on ${target_mount_point} " 'index($0,p){found=1} END{exit !found}'; then
+				echo "volume target already mounted with different source: ${target_mount_point}" >&2
+				return 1
+			fi
+			continue
+		fi
+		if [ "${MOUNT_MODE}" = "ro" ]; then
+			if ! mount -t null -o ro "${VOLUME_PATH}" "${target_mount_point}"; then
+				for rollback_target in ${mounted_targets}; do
+					rmpt="${ROOT_DIR}${rollback_target}"
+					umount "${rmpt}" >/dev/null 2>&1 || true
+				done
+				return 1
+			fi
+		else
+			if ! mount -t null "${VOLUME_PATH}" "${target_mount_point}"; then
+				for rollback_target in ${mounted_targets}; do
+					rmpt="${ROOT_DIR}${rollback_target}"
+					umount "${rmpt}" >/dev/null 2>&1 || true
+				done
+				return 1
+			fi
+		fi
+		mounted_targets="${MOUNT_TARGET} ${mounted_targets}"
+	done
+}
+
+umount_cell_volumes() {
+	while :; do
+		mp=$(mount | awk -v root="${ROOT_DIR}/" '
+			{
+				if (index($0, " on " root) == 0)
+					next
+				line = $0
+				on_pos = index(line, " on ")
+				if (on_pos == 0)
+					next
+				rest = substr(line, on_pos + 4)
+				type_pos = index(rest, " type ")
+				if (type_pos == 0)
+					next
+				mp = substr(rest, 1, type_pos - 1)
+				if (mp == root "dev" || mp == root "dev/pts" || mp == root ".overlay")
+					next
+				if (length(mp) > best_len) {
+					best = mp
+					best_len = length(mp)
+				}
+			}
+			END {
+				if (best_len > 0)
+					print best
+			}
+		')
+		[ -n "${mp}" ] || break
+		umount "${mp}"
+	done
+}
+
+# Compose the final cell root by overlaying writable per-cell directories on
+# top of the shared read-only base layer.
+mount_cell_root() {
+	ensure_base_writable_links
+
+	if mount | awk -v p="on ${ROOT_DIR} " \
+	    'index($0,p){found=1} END{exit !found}'; then
+		return
+	fi
+
+	mount -t null -o ro "${BASE_LAYER}" "${ROOT_DIR}"
+	mount -t null "${OVERLAY_DIR}" "${ROOT_DIR}/.overlay"
+	setup_local_dev
+	mount_cell_volumes
+}
+
+umount_cell_root() {
+	if ! umount_cell_volumes; then
+		return 1
+	fi
+	for d in dev/pts dev .overlay ""; do
+		mp="${ROOT_DIR}${d:+/$d}"
+		if mount | awk -v p="on ${mp} " 'index($0,p){found=1} END{exit !found}'; then
+			umount "${mp}"
+		fi
+	done
+}
+
+write_runtime_cell_conf() {
+	name=$1
+	autostart=${2:-NO}
+	supervise_cmd=${3:-/bin/true}
+	create_profile=${4:-}
+	create_reserved_ports=${5:-}
+	create_rlimit_nofile=${6:-}
+	create_rlimit_as=${7:-}
+	create_rlimit_core=${8:-}
+	supervise_facility=${9:-}
+	supervise_stdout_level=${10:-}
+	supervise_stderr_level=${11:-}
+	supervise_tag=${12:-}
+	depends_on=${13:-}
+	healthcheck_cmd=${14:-}
+	volume_mounts=${15:-}
+
+	escaped_create_profile=$(escape_dq "${create_profile}")
+	escaped_create_reserved_ports=$(escape_dq "${create_reserved_ports}")
+	escaped_create_rlimit_nofile=$(escape_dq "${create_rlimit_nofile}")
+	escaped_create_rlimit_as=$(escape_dq "${create_rlimit_as}")
+	escaped_create_rlimit_core=$(escape_dq "${create_rlimit_core}")
+	escaped_supervise_cmd=$(escape_dq "${supervise_cmd}")
+	escaped_supervise_facility=$(escape_dq "${supervise_facility}")
+	escaped_supervise_stdout_level=$(escape_dq "${supervise_stdout_level}")
+	escaped_supervise_stderr_level=$(escape_dq "${supervise_stderr_level}")
+	escaped_supervise_tag=$(escape_dq "${supervise_tag}")
+	escaped_depends_on=$(escape_dq "${depends_on}")
+	escaped_healthcheck_cmd=$(escape_dq "${healthcheck_cmd}")
+	escaped_volume_mounts=$(escape_dq "${volume_mounts}")
+
+	cat > "${CELL_CONF}" <<CONF
+# autogenerated by cellmgr apply
+CELL_NAME=${name}
+CELL_RELEASE=${RELEASE}
+CELL_ARCH=${MACHINE_ARCH}
+CELL_AUTOSTART=${autostart}
+# Optional cellctl create(8) policy controls:
+CELL_CREATE_PROFILE="${escaped_create_profile}"
+CELL_CREATE_RESERVED_PORTS="${escaped_create_reserved_ports}"
+CELL_CREATE_RLIMIT_NOFILE="${escaped_create_rlimit_nofile}"
+CELL_CREATE_RLIMIT_AS="${escaped_create_rlimit_as}"
+CELL_CREATE_RLIMIT_CORE="${escaped_create_rlimit_core}"
+# Optional cellctl supervise(8) logging controls:
+CELL_SUPERVISE_FACILITY="${escaped_supervise_facility}"
+CELL_SUPERVISE_STDOUT_LEVEL="${escaped_supervise_stdout_level}"
+CELL_SUPERVISE_STDERR_LEVEL="${escaped_supervise_stderr_level}"
+CELL_SUPERVISE_TAG="${escaped_supervise_tag}"
+# One supervised service command per cell:
+CELL_SUPERVISE_CMD="${escaped_supervise_cmd}"
+# Declarative orchestration metadata:
+CELL_DEPENDS_ON="${escaped_depends_on}"
+CELL_HEALTHCHECK_CMD="${escaped_healthcheck_cmd}"
+# Declarative volume mounts (<volume>:<target>:<ro|rw>):
+CELL_VOLUME_MOUNTS="${escaped_volume_mounts}"
+CONF
+}
+
+# Create persistent on-disk cell structure and write rendered runtime cell.conf.
+create_cell() {
+	need_root
+	require_tools
+	name=$1
+	autostart=${2:-NO}
+	supervise_cmd=${3:-/bin/true}
+	create_profile=${4:-}
+	create_reserved_ports=${5:-}
+	create_rlimit_nofile=${6:-}
+	create_rlimit_as=${7:-}
+	create_rlimit_core=${8:-}
+	supervise_facility=${9:-}
+	supervise_stdout_level=${10:-}
+	supervise_stderr_level=${11:-}
+	supervise_tag=${12:-}
+	depends_on=${13:-}
+	healthcheck_cmd=${14:-}
+	volume_mounts=${15:-}
+
+	cell_paths "${name}"
+	mkdir -p "${ROOT_DIR}" "${DATA_VAR_DIR}" "${DATA_TMP_DIR}" \
+		"${DATA_HOME_DIR}" "${DATA_ROOT_DIR}" "${DATA_PKG_DIR}" \
+		"${DATA_VAR_DIR}/run" "${DATA_VAR_DIR}/log" "${STATE_DIR}"
+	chmod 1777 "${DATA_TMP_DIR}"
+	setup_etc
+	write_runtime_cell_conf "${name}" "${autostart}" "${supervise_cmd}" \
+	    "${create_profile}" "${create_reserved_ports}" \
+	    "${create_rlimit_nofile}" "${create_rlimit_as}" "${create_rlimit_core}" \
+	    "${supervise_facility}" "${supervise_stdout_level}" \
+	    "${supervise_stderr_level}" "${supervise_tag}" \
+	    "${depends_on}" "${healthcheck_cmd}" \
+	    "${volume_mounts}"
+
+	echo "Rendered runtime cell ${name}"
+}
+
+cell_exists() {
+	name=$1
+	cellctl list -T -H 2>/dev/null |
+	    awk -F '\t' -v n="${name}" '$2==n{found=1} END{exit !found}'
+}
+
+# Start sequence: load config, mount root overlays, allocate kernel cell ID
+# through cellctl create, then optionally launch supervised workload with
+# cellctl supervise.
+start_cell_internal() {
+	need_root
+	require_tools
+	name=$1
+	supervise=${2:-YES}
+
+	load_cell_conf "${name}"
+	effective_supervise_cmd=${CELL_SUPERVISE_CMD:-}
+	if [ "${supervise}" = "YES" ] && [ -z "${effective_supervise_cmd}" ]; then
+		echo "CELL_SUPERVISE_CMD must be set in ${CELL_CONF}" \
+		    "(example: /bin/sleep 60)" >&2
+		exit 1
+	fi
+
+	cell_paths "${name}"
+	if [ ! -d "${ROOT_DIR}" ] || [ ! -r "${CELL_CONF}" ]; then
+		echo "missing rendered runtime state for ${name}; run: cellmgr apply --all" >&2
+		exit 1
+	fi
+	mount_cell_root
+
+	if cell_exists "${name}"; then
+		cid=$(cell_cid_by_name "${name}" || true)
+		if [ -z "${cid}" ]; then
+			echo "failed to resolve CID for running cell ${name}" >&2
+			exit 1
+		fi
+		if [ "${supervise}" != "YES" ]; then
+			echo "Cell ${name} already running"
+			return
+		fi
+
+		monitor_pid=$(cell_monitor_pid "${name}" "${cid}" || true)
+		if [ -n "${monitor_pid}" ]; then
+			echo "Cell ${name} already running"
+			return
+		fi
+	else
+		set -- cellctl create -n "${name}"
+		# Persisted cellmgr values map 1:1 to cellctl create options.
+		if [ -n "${CELL_CREATE_PROFILE:-}" ]; then
+			set -- "$@" -l "${CELL_CREATE_PROFILE}"
+		fi
+		if [ -n "${CELL_CREATE_RESERVED_PORTS:-}" ]; then
+			set -- "$@" -r "${CELL_CREATE_RESERVED_PORTS}"
+		fi
+		if [ -n "${CELL_CREATE_RLIMIT_NOFILE:-}" ]; then
+			set -- "$@" -N "${CELL_CREATE_RLIMIT_NOFILE}"
+		fi
+		if [ -n "${CELL_CREATE_RLIMIT_AS:-}" ]; then
+			set -- "$@" -A "${CELL_CREATE_RLIMIT_AS}"
+		fi
+		if [ -n "${CELL_CREATE_RLIMIT_CORE:-}" ]; then
+			set -- "$@" -C "${CELL_CREATE_RLIMIT_CORE}"
+		fi
+		set -- "$@" "${ROOT_DIR}"
+		# cellctl create/supervise print "cell <cid>" on stdout; keep cellmgr
+		# output concise and only show the high-level status line below.
+		"$@" >/dev/null
+	fi
+
+	if [ "${supervise}" = "YES" ]; then
+		set -- cellctl supervise
+		if [ -n "${CELL_SUPERVISE_FACILITY:-}" ]; then
+			set -- "$@" -f "${CELL_SUPERVISE_FACILITY}"
+		fi
+		if [ -n "${CELL_SUPERVISE_STDOUT_LEVEL:-}" ]; then
+			set -- "$@" -o "${CELL_SUPERVISE_STDOUT_LEVEL}"
+		fi
+		if [ -n "${CELL_SUPERVISE_STDERR_LEVEL:-}" ]; then
+			set -- "$@" -e "${CELL_SUPERVISE_STDERR_LEVEL}"
+		fi
+		if [ -n "${CELL_SUPERVISE_TAG:-}" ]; then
+			set -- "$@" -t "${CELL_SUPERVISE_TAG}"
+		fi
+		# Keep CELL_SUPERVISE_CMD as a shell command string so quoted arguments
+		# (e.g. su -c '...') remain intact.
+		set -- "$@" "${name}" /bin/sh -c "exec ${effective_supervise_cmd}"
+		"$@" >/dev/null
+	fi
+	echo "Started cell ${name}"
+}
+
+start_cell() {
+	start_cell_internal "$1" "YES"
+}
+
+# Stop sequence mirrors startup in reverse: stop supervisor, destroy kernel
+# cell object, then unmount filesystem overlays.
+stop_cell() {
+	need_root
+	require_tools
+	name=$1
+	cell_paths "${name}"
+
+	if cell_exists "${name}"; then
+		cid=$(cell_cid_by_name "${name}" || true)
+		if [ -z "${cid}" ]; then
+			echo "failed to resolve CID for running cell ${name}" >&2
+			exit 1
+		fi
+		stop_cell_processes "${name}" "${cid}"
+		cellctl destroy "${cid}"
+		echo "Destroyed cell ${name} (cid ${cid})"
+	fi
+
+	if [ -r "${CELL_CONF}" ]; then
+		load_cell_conf "${name}"
+	else
+		CELL_VOLUME_MOUNTS=
+	fi
+
+	if [ -d "${ROOT_DIR}" ]; then
+		umount_cell_root || true
+	fi
+}
+
+start_all() {
+	failed=0
+	for cell_conf in "${CELL_DATA_DIR}"/*/cell.conf; do
+		[ -f "${cell_conf}" ] || continue
+		name=${cell_conf%/cell.conf}
+		name=${name##*/}
+		if ! start_cell "${name}"; then
+			failed=1
+			echo "Failed to start cell ${name}; continuing" >&2
+		fi
+	done
+	if [ "${failed}" -ne 0 ]; then
+		exit 1
+	fi
+}
+
+stop_all() {
+	for cell_conf in "${CELL_DATA_DIR}"/*/cell.conf; do
+		[ -f "${cell_conf}" ] || continue
+		name=${cell_conf%/cell.conf}
+		name=${name##*/}
+		stop_cell "${name}"
+	done
+}
+
+cell_cid_by_name() {
+	name=$1
+	cellctl list -T -H 2>/dev/null |
+	    awk -F '\t' -v n="${name}" '$2==n{print $1; exit}'
+}
+
+require_apply_tools() {
+	for t in cellctl mktemp cp dirname; do
+		command -v "${t}" >/dev/null 2>&1 || {
+			echo "missing required tool: ${t}" >&2
+			exit 1
+		}
+	done
+}
+
+trim_ws() {
+	printf '%s' "$1" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//'
+}
+
+quote_sh() {
+	printf '%s' "$1" | sed -e "s/'/'\\\\''/g" -e "1s/^/'/" -e "\$s/\$/'/"
+}
+
+validate_pkg_name() {
+	pkg=$1
+	case "${pkg}" in
+	*[!A-Za-z0-9._+-]*|"")
+		echo "invalid package token in apply plan: ${pkg}" >&2
+		return 1
+		;;
+	esac
+	return 0
+}
+
+apply_exec_in_cell() {
+	cell_cid=$1
+	action_cmd=$2
+	qpkg_path=$(quote_sh "${PKG_PATH}")
+	cellctl exec "${cell_cid}" /bin/sh -c "export PKG_PATH=${qpkg_path}; ${action_cmd}"
+}
+
+apply_write_block_file() {
+	cell_cid=$1
+	target_path=$2
+	host_block_file=$3
+	mode=${4:-}
+	owner=${5:-}
+	group=${6:-}
+
+	case "${target_path}" in
+	/*)
+		;;
+	*)
+		echo "FILE_BEGIN target must be an absolute path: ${target_path}" >&2
+		return 1
+		;;
+	esac
+
+	if command -v uuidgen >/dev/null 2>&1; then
+		block_id=$(uuidgen | tr -d '-')
+	else
+		block_id="$(date +%s)-$$"
+	fi
+
+	cell_tmp_path="/tmp/cellmgr-apply-block-${block_id}.tmp"
+	host_stage_path="${ROOT_DIR}${cell_tmp_path}"
+	if ! cp "${host_block_file}" "${host_stage_path}"; then
+		echo "failed to stage block content for ${target_path}" >&2
+		return 1
+	fi
+
+	target_dir=$(dirname "${target_path}")
+	qcell_tmp=$(quote_sh "${cell_tmp_path}")
+	qtarget=$(quote_sh "${target_path}")
+	qtarget_dir=$(quote_sh "${target_dir}")
+
+	cmd="mkdir -p ${qtarget_dir} && if [ -f ${qtarget} ] && cmp -s ${qcell_tmp} ${qtarget}; then rm -f ${qcell_tmp}; else mv -f ${qcell_tmp} ${qtarget}; fi"
+	if [ -n "${mode}" ]; then
+		cmd="${cmd} && chmod ${mode} ${qtarget}"
+	fi
+	if [ -n "${owner}" ] && [ -n "${group}" ]; then
+		cmd="${cmd} && chown ${owner}:${group} ${qtarget}"
+	elif [ -n "${owner}" ]; then
+		cmd="${cmd} && chown ${owner} ${qtarget}"
+	elif [ -n "${group}" ]; then
+		cmd="${cmd} && chgrp ${group} ${qtarget}"
+	fi
+
+	if apply_exec_in_cell "${cell_cid}" "${cmd}"; then
+		rc=0
+	else
+		rc=$?
+	fi
+	rm -f "${host_stage_path}" || true
+	return "${rc}"
+}
+
+apply_patch_block() {
+	cell_cid=$1
+	target_path=$2
+	host_patch_file=$3
+	strip_level=${4:-0}
+
+	case "${target_path}" in
+	/*)
+		;;
+	*)
+		echo "PATCH_BEGIN target must be an absolute path: ${target_path}" >&2
+		return 1
+		;;
+	esac
+
+	case "${strip_level}" in
+	*[!0-9]*|"")
+		echo "PATCH_BEGIN strip must be a non-negative integer: ${strip_level}" >&2
+		return 1
+		;;
+	esac
+
+	if command -v uuidgen >/dev/null 2>&1; then
+		patch_id=$(uuidgen | tr -d '-')
+	else
+		patch_id="$(date +%s)-$$"
+	fi
+
+	cell_tmp_patch="/tmp/cellmgr-apply-patch-${patch_id}.diff"
+	host_stage_patch="${ROOT_DIR}${cell_tmp_patch}"
+	if ! cp "${host_patch_file}" "${host_stage_patch}"; then
+		echo "failed to stage patch snippet for ${target_path}" >&2
+		return 1
+	fi
+
+	qtarget=$(quote_sh "${target_path}")
+	qpatch=$(quote_sh "${cell_tmp_patch}")
+
+	cmd="command -v patch >/dev/null 2>&1 || { echo 'missing patch(1) in cell' >&2; exit 1; }; [ -f ${qtarget} ] || { echo 'PATCH target missing: ${target_path}' >&2; exit 1; }; if patch -N -p${strip_level} --dry-run ${qtarget} < ${qpatch} >/dev/null 2>&1; then patch -N -p${strip_level} ${qtarget} < ${qpatch} >/dev/null 2>&1; elif patch -R -p${strip_level} --dry-run ${qtarget} < ${qpatch} >/dev/null 2>&1; then :; else patch -N -p${strip_level} ${qtarget} < ${qpatch}; fi; rm -f ${qpatch}"
+
+	if apply_exec_in_cell "${cell_cid}" "${cmd}"; then
+		rc=0
+	else
+		rc=$?
+	fi
+	rm -f "${host_stage_patch}" || true
+	return "${rc}"
+}
+
+apply_declarative_plan() {
+	cell_cid=$1
+	plan_file=$2
+	line_no=0
+	block_active=NO
+	block_target=
+	block_mode=
+	block_owner=
+	block_group=
+	block_strip=0
+	block_tmp_file=
+	block_kind=
+	block_end_token=
+
+	while IFS= read -r raw_line || [ -n "${raw_line}" ]; do
+		line_no=$((line_no + 1))
+
+		if [ "${block_active}" = "YES" ]; then
+			line=$(trim_ws "${raw_line}")
+			if [ "${line}" = "${block_end_token}" ]; then
+				if [ "${block_kind}" = "FILE" ]; then
+					if ! apply_write_block_file "${cell_cid}" "${block_target}" \
+					    "${block_tmp_file}" "${block_mode}" \
+					    "${block_owner}" "${block_group}"; then
+						rm -f "${block_tmp_file}" || true
+						return 1
+					fi
+				elif [ "${block_kind}" = "PATCH" ]; then
+					if ! apply_patch_block "${cell_cid}" "${block_target}" \
+					    "${block_tmp_file}" "${block_strip}"; then
+						rm -f "${block_tmp_file}" || true
+						return 1
+					fi
+				else
+					echo "internal error: unknown block kind ${block_kind}" >&2
+					rm -f "${block_tmp_file}" || true
+					return 1
+				fi
+				rm -f "${block_tmp_file}" || true
+				block_active=NO
+				block_target=
+				block_mode=
+				block_owner=
+				block_group=
+				block_strip=0
+				block_tmp_file=
+				block_kind=
+				block_end_token=
+				continue
+			fi
+			printf '%s\n' "${raw_line}" >> "${block_tmp_file}"
+			continue
+		fi
+
+		line=$(trim_ws "${raw_line}")
+		[ -n "${line}" ] || continue
+		case "${line}" in
+		\#*)
+			continue
+			;;
+		esac
+
+		op=${line%%[[:space:]]*}
+		upper_op=$(printf '%s' "${op}" | tr '[:lower:]' '[:upper:]')
+		if [ "${op}" != "${upper_op}" ]; then
+			echo "${plan_file}:${line_no}: directive must be uppercase: ${op}" >&2
+			return 1
+		fi
+		op=${upper_op}
+		if [ "${op}" = "${line}" ]; then
+			rest=
+		else
+			rest=$(trim_ws "${line#"${line%%[[:space:]]*}"}")
+		fi
+
+		case "${op}" in
+		PKG)
+			[ -n "${rest}" ] || {
+				echo "${plan_file}:${line_no}: PKG requires at least one package" >&2
+				return 1
+			}
+			set -f
+			set -- ${rest}
+			set +f
+			for pkg in "$@"; do
+				validate_pkg_name "${pkg}" || return 1
+				qpkg=$(quote_sh "${pkg}")
+				qpattern=$(quote_sh "${pkg}-*")
+				apply_exec_in_cell "${cell_cid}" \
+				    "if ! pkg_info -qe ${qpattern} >/dev/null 2>&1; then pkg_add ${qpkg}; fi" || return 1
+			done
+			;;
+		EXEC)
+			[ -n "${rest}" ] || {
+				echo "${plan_file}:${line_no}: EXEC requires a command" >&2
+				return 1
+			}
+			apply_exec_in_cell "${cell_cid}" "${rest}" || return 1
+			;;
+		DIR)
+			[ -n "${rest}" ] || {
+				echo "${plan_file}:${line_no}: DIR requires a path" >&2
+				return 1
+			}
+			set -f
+			set -- ${rest}
+			set +f
+			[ $# -ge 1 ] || {
+				echo "${plan_file}:${line_no}: DIR requires a path" >&2
+				return 1
+			}
+			path=$1
+			shift
+			mode=
+			owner=
+			group=
+			for opt in "$@"; do
+				case "${opt}" in
+				mode=*)
+					mode=${opt#mode=}
+					;;
+				owner=*)
+					owner=${opt#owner=}
+					;;
+				group=*)
+					group=${opt#group=}
+					;;
+				*)
+					echo "${plan_file}:${line_no}: unknown DIR option: ${opt}" >&2
+					return 1
+					;;
+				esac
+			done
+			qpath=$(quote_sh "${path}")
+			cmd="mkdir -p ${qpath}"
+			if [ -n "${mode}" ]; then
+				cmd="${cmd} && chmod ${mode} ${qpath}"
+			fi
+			if [ -n "${owner}" ] && [ -n "${group}" ]; then
+				cmd="${cmd} && chown ${owner}:${group} ${qpath}"
+			elif [ -n "${owner}" ]; then
+				cmd="${cmd} && chown ${owner} ${qpath}"
+			elif [ -n "${group}" ]; then
+				cmd="${cmd} && chgrp ${group} ${qpath}"
+			fi
+			apply_exec_in_cell "${cell_cid}" "${cmd}" || return 1
+			;;
+		LINE)
+			case "${rest}" in
+			*'|'*)
+				path=$(trim_ws "${rest%%|*}")
+				text=$(trim_ws "${rest#*|}")
+				;;
+			*)
+				echo "${plan_file}:${line_no}: LINE requires '<path> | <text>'" >&2
+				return 1
+				;;
+			esac
+			[ -n "${path}" ] || {
+				echo "${plan_file}:${line_no}: LINE path cannot be empty" >&2
+				return 1
+			}
+			qpath=$(quote_sh "${path}")
+			qtext=$(quote_sh "${text}")
+			apply_exec_in_cell "${cell_cid}" \
+			    "touch ${qpath} && (grep -F -x -- ${qtext} ${qpath} >/dev/null 2>&1 || printf '%s\\n' ${qtext} >> ${qpath})" || return 1
+			;;
+		SYMLINK)
+			[ -n "${rest}" ] || {
+				echo "${plan_file}:${line_no}: SYMLINK requires '<target> <linkpath>'" >&2
+				return 1
+			}
+			set -f
+			set -- ${rest}
+			set +f
+			if [ $# -ne 2 ]; then
+				echo "${plan_file}:${line_no}: SYMLINK requires exactly two arguments" >&2
+				return 1
+			fi
+			qtarget=$(quote_sh "$1")
+			qlink=$(quote_sh "$2")
+			apply_exec_in_cell "${cell_cid}" "ln -snf ${qtarget} ${qlink}" || return 1
+			;;
+		PATCH_BEGIN)
+			[ -n "${rest}" ] || {
+				echo "${plan_file}:${line_no}: PATCH_BEGIN requires a target path" >&2
+				return 1
+			}
+			set -f
+			set -- ${rest}
+			set +f
+			[ $# -ge 1 ] || {
+				echo "${plan_file}:${line_no}: PATCH_BEGIN requires a target path" >&2
+				return 1
+			}
+			block_target=$1
+			shift
+			block_strip=0
+			for opt in "$@"; do
+				case "${opt}" in
+				strip=*)
+					block_strip=${opt#strip=}
+					;;
+				*)
+					echo "${plan_file}:${line_no}: unknown PATCH_BEGIN option: ${opt}" >&2
+					return 1
+					;;
+				esac
+			done
+			case "${block_target}" in
+			/*)
+				;;
+			*)
+				echo "${plan_file}:${line_no}: PATCH_BEGIN target must be absolute" >&2
+				return 1
+				;;
+			esac
+			case "${block_strip}" in
+			*[!0-9]*|"")
+				echo "${plan_file}:${line_no}: PATCH_BEGIN strip must be integer" >&2
+				return 1
+				;;
+			esac
+			block_tmp_file=$(mktemp /tmp/cellmgr-apply-patch.XXXXXX)
+			block_active=YES
+			block_kind=PATCH
+			block_end_token=PATCH_END
+			;;
+		PATCH_END)
+			echo "${plan_file}:${line_no}: PATCH_END without PATCH_BEGIN" >&2
+			return 1
+			;;
+		FILE_BEGIN)
+			[ -n "${rest}" ] || {
+				echo "${plan_file}:${line_no}: FILE_BEGIN requires a target path" >&2
+				return 1
+			}
+			set -f
+			set -- ${rest}
+			set +f
+			[ $# -ge 1 ] || {
+				echo "${plan_file}:${line_no}: FILE_BEGIN requires a target path" >&2
+				return 1
+			}
+			block_target=$1
+			shift
+			block_mode=
+			block_owner=
+			block_group=
+			for opt in "$@"; do
+				case "${opt}" in
+				mode=*)
+					block_mode=${opt#mode=}
+					;;
+				owner=*)
+					block_owner=${opt#owner=}
+					;;
+				group=*)
+					block_group=${opt#group=}
+					;;
+				*)
+					echo "${plan_file}:${line_no}: unknown FILE_BEGIN option: ${opt}" >&2
+					return 1
+					;;
+				esac
+			done
+			case "${block_target}" in
+			/*)
+				;;
+			*)
+				echo "${plan_file}:${line_no}: FILE_BEGIN target must be absolute" >&2
+				return 1
+				;;
+			esac
+			block_tmp_file=$(mktemp /tmp/cellmgr-apply-block.XXXXXX)
+			block_active=YES
+			block_kind=FILE
+			block_end_token=FILE_END
+			;;
+		FILE_END)
+			echo "${plan_file}:${line_no}: FILE_END without FILE_BEGIN" >&2
+			return 1
+			;;
+		*)
+			echo "${plan_file}:${line_no}: unknown directive: ${op}" >&2
+			return 1
+			;;
+		esac
+	done < "${plan_file}"
+
+	if [ "${block_active}" = "YES" ]; then
+		echo "${plan_file}:${line_no}: missing ${block_end_token} for ${block_kind}_BEGIN ${block_target}" >&2
+		rm -f "${block_tmp_file}" || true
+		return 1
+	fi
+
+	return 0
+}
+
+apply_cell_script() {
+	need_root
+	require_tools
+	require_apply_tools
+
+	ephemeral=NO
+	while [ $# -gt 0 ]; do
+		case "$1" in
+		--ephemeral)
+			ephemeral=YES
+			shift
+			;;
+		--)
+			shift
+			break
+			;;
+		-*)
+			usage
+			exit 1
+			;;
+		*)
+			break
+			;;
+		esac
+	done
+
+	if [ $# -lt 1 ]; then
+		usage
+		exit 1
+	fi
+
+	name=$1
+	shift
+
+	plan_source=
+	if [ $# -gt 0 ]; then
+		plan_source=$1
+		shift
+	fi
+	if [ $# -ne 0 ]; then
+		usage
+		exit 1
+	fi
+
+	if [ -z "${plan_source}" ]; then
+		manifest_cell_paths "${name}"
+		plan_source=${MANIFEST_APPLY_FILE}
+	fi
+
+	if [ ! -r "${plan_source}" ]; then
+		echo "apply: cannot read declarative plan: ${plan_source}" >&2
+		exit 1
+	fi
+
+	load_cell_conf "${name}"
+	cell_paths "${name}"
+
+	started_by_apply=NO
+	if ! cell_exists "${name}"; then
+		start_cell_internal "${name}" "NO"
+		started_by_apply=YES
+	fi
+
+	cell_paths "${name}"
+	cell_cid=$(cell_cid_by_name "${name}" || true)
+	if [ -z "${cell_cid}" ]; then
+		echo "apply: failed to resolve CID for cell ${name}" >&2
+		exit 1
+	fi
+
+	if ! apply_exec_in_cell "${cell_cid}" \
+	    "command -v certctl >/dev/null 2>&1 || { echo 'missing certctl(8) in cell' >&2; exit 1; }; certctl rehash"; then
+		echo "apply: certctl rehash failed in cell ${name}" >&2
+		exit 1
+	fi
+
+	if apply_declarative_plan "${cell_cid}" "${plan_source}"; then
+		apply_rc=0
+	else
+		apply_rc=$?
+	fi
+
+	stop_rc=0
+	if [ "${ephemeral}" = "YES" ] && [ "${started_by_apply}" = "YES" ]; then
+		if ! stop_cell "${name}"; then
+			stop_rc=$?
+		fi
+	fi
+
+	if [ "${apply_rc}" -ne 0 ]; then
+		return "${apply_rc}"
+	fi
+	return "${stop_rc}"
+}
