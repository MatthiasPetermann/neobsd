+load_manifest_cell_conf() {
+	manifest_cell_name=$1
+	manifest_cell_paths "${manifest_cell_name}"
+	if [ ! -r "${MANIFEST_CELL_CONF}" ]; then
+		echo "missing manifest ${MANIFEST_CELL_CONF}" >&2
+		exit 1
+	fi
+
+	CELL_NAME=
+	CELL_SUPERVISE_CMD=
+	CELL_CREATE_PROFILE=
+	CELL_CREATE_RESERVED_PORTS=
+	CELL_CREATE_RLIMIT_NOFILE=
+	CELL_CREATE_RLIMIT_AS=
+	CELL_CREATE_RLIMIT_CORE=
+	CELL_SUPERVISE_FACILITY=
+	CELL_SUPERVISE_STDOUT_LEVEL=
+	CELL_SUPERVISE_STDERR_LEVEL=
+	CELL_SUPERVISE_TAG=
+	CELL_AUTOSTART=NO
+	CELL_DEPENDS_ON=
+	CELL_HEALTHCHECK_CMD=
+	CELL_VOLUME_MOUNTS=
+	# shellcheck disable=SC1090
+	. "${MANIFEST_CELL_CONF}"
+
+	if [ -z "${CELL_NAME:-}" ]; then
+		CELL_NAME=${manifest_cell_name}
+	fi
+	if [ "${CELL_NAME}" != "${manifest_cell_name}" ]; then
+		echo "manifest mismatch: expected CELL_NAME=${manifest_cell_name}, got ${CELL_NAME}" >&2
+		exit 1
+	fi
+	manifest_name=${CELL_NAME}
+
+	CELL_AUTOSTART=$(normalize_yesno "${CELL_AUTOSTART:-NO}")
+
+	if [ -z "${CELL_SUPERVISE_CMD:-}" ]; then
+		echo "manifest ${MANIFEST_CELL_CONF}: CELL_SUPERVISE_CMD is required" >&2
+		exit 1
+	fi
+	for dep in $(normalize_dep_list "${CELL_DEPENDS_ON:-}"); do
+		assert_valid_cell_name "${dep}"
+		if [ "${dep}" = "${manifest_name}" ]; then
+			echo "manifest ${MANIFEST_CELL_CONF}: self dependency is not allowed" >&2
+			exit 1
+		fi
+	done
+	if ! validate_cell_volume_mounts "${CELL_VOLUME_MOUNTS:-}" "manifest ${MANIFEST_CELL_CONF}" YES; then
+		exit 1
+	fi
+	CELL_VOLUME_MOUNTS=${CELL_VOLUME_MOUNTS_NORMALIZED}
+}
+
+create_manifest_cell() {
+	need_root
+	name=$1
+	autostart=$2
+	supervise_cmd=$3
+	create_profile=$4
+	create_reserved_ports=$5
+	create_rlimit_nofile=$6
+	create_rlimit_as=$7
+	create_rlimit_core=$8
+	supervise_facility=$9
+	supervise_stdout_level=${10:-}
+	supervise_stderr_level=${11:-}
+	supervise_tag=${12:-}
+	depends_on=${13:-}
+	healthcheck_cmd=${14:-}
+	volume_mounts=${15:-}
+
+	assert_valid_cell_name "${name}"
+	if [ -z "${supervise_cmd}" ]; then
+		supervise_cmd=/bin/true
+	fi
+
+	for dep in $(normalize_dep_list "${depends_on}"); do
+		assert_valid_cell_name "${dep}"
+		if [ "${dep}" = "${name}" ]; then
+			echo "cell ${name} cannot depend on itself" >&2
+			exit 1
+		fi
+	done
+	if ! validate_cell_volume_mounts "${volume_mounts}" "create ${name}" NO; then
+		exit 1
+	fi
+	volume_mounts=${CELL_VOLUME_MOUNTS_NORMALIZED}
+
+	ensure_manifest_layout write
+	manifest_cell_paths "${name}"
+	if [ -e "${MANIFEST_CELL_CONF}" ]; then
+		echo "manifest already exists: ${MANIFEST_CELL_CONF}" >&2
+		exit 1
+	fi
+	write_manifest_cell_conf_file "${name}" "${autostart}" "${supervise_cmd}" \
+	    "${create_profile}" "${create_reserved_ports}" \
+	    "${create_rlimit_nofile}" "${create_rlimit_as}" "${create_rlimit_core}" \
+	    "${supervise_facility}" "${supervise_stdout_level}" \
+	    "${supervise_stderr_level}" "${supervise_tag}" \
+	    "${depends_on}" "${healthcheck_cmd}" "${volume_mounts}"
+
+	if [ -f "${MANIFEST_APPLY_FILE}" ]; then
+		echo "apply plan already exists: ${MANIFEST_APPLY_FILE}" >&2
+		exit 1
+	fi
+
+	cat > "${MANIFEST_APPLY_FILE}" <<'CONF'
+# declarative apply plan for cellmgr apply
+#
+# supported directives:
+#   PKG <package>
+#   DIR <path> [mode=0755] [owner=user] [group=group]
+#   LINE <path> | <text>
+#   SYMLINK <target> <linkpath>
+#   EXEC <command>
+#   FILE_BEGIN <path> [mode=0644] [owner=user] [group=group]
+#   ... block lines ...
+#   FILE_END
+#   PATCH_BEGIN <path> [strip=0]
+#   ... unified diff snippet ...
+#   PATCH_END
+
+# PKG postgresql16-server
+# DIR /var/postgresql/data mode=0700 owner=pgsql group=pgsql
+# EXEC if [ ! -s /var/postgresql/data/PG_VERSION ]; then su -m pgsql -c '/usr/pkg/bin/initdb -D /var/postgresql/data'; fi
+CONF
+	echo "Created manifest ${MANIFEST_CELL_CONF}"
+}
+
+write_manifest_cell_conf_file() {
+	name=$1
+	autostart=$2
+	supervise_cmd=$3
+	create_profile=$4
+	create_reserved_ports=$5
+	create_rlimit_nofile=$6
+	create_rlimit_as=$7
+	create_rlimit_core=$8
+	supervise_facility=$9
+	supervise_stdout_level=${10:-}
+	supervise_stderr_level=${11:-}
+	supervise_tag=${12:-}
+	depends_on=${13:-}
+	healthcheck_cmd=${14:-}
+	volume_mounts=${15:-}
+
+	escaped_create_profile=$(escape_dq "${create_profile}")
+	escaped_create_reserved_ports=$(escape_dq "${create_reserved_ports}")
+	escaped_create_rlimit_nofile=$(escape_dq "${create_rlimit_nofile}")
+	escaped_create_rlimit_as=$(escape_dq "${create_rlimit_as}")
+	escaped_create_rlimit_core=$(escape_dq "${create_rlimit_core}")
+	escaped_supervise_cmd=$(escape_dq "${supervise_cmd}")
+	escaped_supervise_facility=$(escape_dq "${supervise_facility}")
+	escaped_supervise_stdout_level=$(escape_dq "${supervise_stdout_level}")
+	escaped_supervise_stderr_level=$(escape_dq "${supervise_stderr_level}")
+	escaped_supervise_tag=$(escape_dq "${supervise_tag}")
+	escaped_depends_on=$(escape_dq "${depends_on}")
+	escaped_healthcheck_cmd=$(escape_dq "${healthcheck_cmd}")
+	escaped_volume_mounts=$(escape_dq "${volume_mounts}")
+
+	cat > "${MANIFEST_CELL_CONF}" <<CONF
+# declarative manifest for cellmgr apply
+CELL_NAME=${name}
+CELL_AUTOSTART=${autostart}
+CELL_CREATE_PROFILE="${escaped_create_profile}"
+CELL_CREATE_RESERVED_PORTS="${escaped_create_reserved_ports}"
+CELL_CREATE_RLIMIT_NOFILE="${escaped_create_rlimit_nofile}"
+CELL_CREATE_RLIMIT_AS="${escaped_create_rlimit_as}"
+CELL_CREATE_RLIMIT_CORE="${escaped_create_rlimit_core}"
+CELL_SUPERVISE_FACILITY="${escaped_supervise_facility}"
+CELL_SUPERVISE_STDOUT_LEVEL="${escaped_supervise_stdout_level}"
+CELL_SUPERVISE_STDERR_LEVEL="${escaped_supervise_stderr_level}"
+CELL_SUPERVISE_TAG="${escaped_supervise_tag}"
+CELL_SUPERVISE_CMD="${escaped_supervise_cmd}"
+CELL_DEPENDS_ON="${escaped_depends_on}"
+CELL_HEALTHCHECK_CMD="${escaped_healthcheck_cmd}"
+CELL_VOLUME_MOUNTS="${escaped_volume_mounts}"
+CONF
+}
+
+set_manifest_cell() {
+	need_root
+	name=$1
+	autostart=$2
+	supervise_cmd=$3
+	create_profile=$4
+	create_reserved_ports=$5
+	create_rlimit_nofile=$6
+	create_rlimit_as=$7
+	create_rlimit_core=$8
+	supervise_facility=$9
+	supervise_stdout_level=${10:-}
+	supervise_stderr_level=${11:-}
+	supervise_tag=${12:-}
+	depends_on=${13:-}
+	healthcheck_cmd=${14:-}
+	volume_mounts=${15:-}
+
+	assert_valid_cell_name "${name}"
