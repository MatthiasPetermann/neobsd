diff --git a/usr.sbin/cellmgr/examples/mantisbt/mantisbt-edge-nginx.apply b/usr.sbin/cellmgr/examples/mantisbt/mantisbt-edge-nginx.apply
new file mode 100644
index 000000000000..98a3acdfc50e
--- /dev/null
+++ b/usr.sbin/cellmgr/examples/mantisbt/mantisbt-edge-nginx.apply
@@ -0,0 +1,39 @@
+# Nginx edge cell forwarding PHP to MantisBT app on localhost:9000
+PKG nginx
+FILE_BEGIN /usr/pkg/etc/nginx/nginx.conf mode=0644
+worker_processes 1;
+daemon off;
+events { worker_connections 1024; }
+error_log /dev/stderr notice;
+pid /tmp/nginx.pid;
+http {
+  include /usr/pkg/etc/nginx/mime.types;
+  default_type application/octet-stream;
+  access_log /dev/stdout combined;
+  server_tokens off;
+  sendfile on;
+  keepalive_timeout 65;
+  client_max_body_size 32m;
+  server {
+    listen 80;
+    server_name _;
+    root /var/www/mantisbt;
+    add_header X-Cellmgr-Edge "mantisbt" always;
+    index index.php index.html;
+
+    location / { try_files $uri $uri/ /index.php?$query_string; }
+
+    location ~ /\.(?!well-known).* {
+      deny all;
+    }
+
+    location ~ \.php$ {
+      include /usr/pkg/etc/nginx/fastcgi_params;
+      fastcgi_param SCRIPT_FILENAME /var/www/mantisbt$fastcgi_script_name;
+      fastcgi_param PATH_INFO $fastcgi_path_info;
+      fastcgi_read_timeout 120s;
+      fastcgi_pass 127.0.0.1:9000;
+    }
+  }
+}
+FILE_END
