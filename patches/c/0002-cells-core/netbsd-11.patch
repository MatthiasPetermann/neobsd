+	    'NAME' 'DESIRED' 'RENDERED' 'RUNNING' 'SUPERVISE_CMD'
+	for cell_conf in "${MANIFEST_DIR}"/*.cell; do
+		[ -f "${cell_conf}" ] || continue
+		name=${cell_conf##*/}
+		name=${name%.cell}
+		load_manifest_cell_conf "${name}"
+		desired=${CELL_AUTOSTART:-NO}
+		if [ -r "${CELL_DATA_DIR}/${name}/cell.conf" ]; then
+			rendered=YES
+		else
+			rendered=NO
+		fi
+		if command -v cellctl >/dev/null 2>&1; then
+			if cell_exists "${name}"; then
+				running=YES
+			else
+				running=NO
+			fi
+		else
+			running=UNKNOWN
+		fi
+		printf '%-20s %-10s %-10s %-10s %-30s\n' \
+			"${name}" "${desired}" "${rendered}" "${running}" \
+			"${CELL_SUPERVISE_CMD:-}"
+	done
