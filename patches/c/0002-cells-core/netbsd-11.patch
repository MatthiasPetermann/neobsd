+runtime_print_human_table() {
+	in_file=$1
+	runtime_age_mode=$(runtime_age_render_mode)
+	awk -F '\t' -v cols="${RUNTIME_OUTPUT_FIELDS}" -v age_mode="${runtime_age_mode}" '
+		function is_bool_field(f) {
+			return (f == "running" || f == "desired_state" || f == "manifest" ||
+			    f == "rendered" || f == "apply_present")
+		}
+		function humanize_age(v, s, m, h, d, w) {
+			if (v == "")
+				return "-"
+			s = v + 0
+			if (s < 60)
+				return s "s"
+			if (s < 3600) {
+				m = int(s / 60)
+				return m "m" (s % 60) "s"
+			}
+			if (s < 86400) {
+				h = int(s / 3600)
+				m = int((s % 3600) / 60)
+				return h "h" m "m"
+			}
+			if (s < 604800) {
+				d = int(s / 86400)
+				h = int((s % 86400) / 3600)
+				return d "d" h "h"
+			}
+			w = int(s / 604800)
+			d = int((s % 604800) / 86400)
+			return w "w" d "d"
+		}
+		function humanize(f, v) {
+			if (f == "age" && age_mode == "human")
+				return humanize_age(v)
+			if (is_bool_field(f)) {
+				if (v == "1")
+					return "YES"
+				if (v == "0")
+					return "NO"
+			}
+			if (v == "")
+				return "-"
+			return v
+		}
+		BEGIN {
+			n = split(cols, names, " ")
+			for (i = 1; i <= n; i++) {
+				headers[i] = toupper(names[i])
+				width[i] = length(headers[i])
+			}
+		}
+		{
+			rows = NR
+			for (i = 1; i <= n; i++) {
+				val = humanize(names[i], $i)
+				cell[NR, i] = val
+				if (length(val) > width[i])
+					width[i] = length(val)
+			}
+		}
+		END {
+			for (i = 1; i <= n; i++) {
+				printf "%-*s", width[i], headers[i]
+				if (i < n)
+					printf "  "
+				else
+					printf "\n"
+			}
+			for (r = 1; r <= rows; r++) {
+				for (i = 1; i <= n; i++) {
+					printf "%-*s", width[i], cell[r, i]
+					if (i < n)
+						printf "  "
+					else
+						printf "\n"
+				}
+			}
+		}
+	' "${in_file}"
+}
