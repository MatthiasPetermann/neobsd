+runtime_parse_output_fields() {
+	requested=${1:-}
+	view=${2:-merged}
+	if [ -z "${requested}" ]; then
+		requested=$(runtime_view_default_fields "${view}") || return 1
+	fi
+
+	RUNTIME_OUTPUT_FIELDS=
+	RUNTIME_OUTPUT_CUT=
+	for field in $(printf '%s' "${requested}" | tr ',' ' '); do
+		case "${field}" in
+		*[!a-z0-9_]*|'')
+			echo "cell: invalid field token '${field}'" >&2
+			return 1
+			;;
+		esac
+
+		if ! runtime_field_allowed "${view}" "${field}"; then
+			echo "cell: field '${field}' is not available in view '${view}'" >&2
+			return 1
+		fi
+
+		if ! idx=$(runtime_field_index "${field}"); then
+			echo "cell: unknown field '${field}'" >&2
+			return 1
+		fi
+
+		if [ -z "${RUNTIME_OUTPUT_FIELDS}" ]; then
+			RUNTIME_OUTPUT_FIELDS=${field}
+			RUNTIME_OUTPUT_CUT=${idx}
+		else
+			RUNTIME_OUTPUT_FIELDS="${RUNTIME_OUTPUT_FIELDS} ${field}"
+			RUNTIME_OUTPUT_CUT="${RUNTIME_OUTPUT_CUT},${idx}"
+		fi
+	done
+
+	if [ -z "${RUNTIME_OUTPUT_FIELDS}" ]; then
+		echo "cell: field list is empty" >&2
+		return 1
+	fi
+}
