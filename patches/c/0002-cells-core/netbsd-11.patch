+runtime_collect_snapshot() {
+	out_file=$1
+	rendered_tmp=$(mktemp /tmp/cellmgr-runtime-rendered.XXXXXX)
+	manifest_tmp=$(mktemp /tmp/cellmgr-runtime-manifest.XXXXXX)
+	list_raw_tmp=$(mktemp /tmp/cellmgr-runtime-list-raw.XXXXXX)
+	list_tmp=$(mktemp /tmp/cellmgr-runtime-list.XXXXXX)
+	stats_raw_tmp=$(mktemp /tmp/cellmgr-runtime-stats-raw.XXXXXX)
+	stats_tmp=$(mktemp /tmp/cellmgr-runtime-stats.XXXXXX)
+	merged_tmp=$(mktemp /tmp/cellmgr-runtime-merged.XXXXXX)
+
+	: > "${rendered_tmp}"
+	: > "${manifest_tmp}"
+	: > "${list_tmp}"
+	: > "${stats_tmp}"
+
+	if ensure_manifest_layout; then
+		for cell_conf in "${MANIFEST_DIR}"/*.cell; do
+			[ -f "${cell_conf}" ] || continue
+			cell_name=${cell_conf##*/}
+			cell_name=${cell_name%.cell}
+			assert_valid_cell_name "${cell_name}"
+			load_manifest_cell_conf "${cell_name}"
+			manifest_autostart=$(runtime_tsv_sanitize "${CELL_AUTOSTART:-NO}")
+			manifest_profile=$(runtime_tsv_sanitize "${CELL_CREATE_PROFILE:-}")
+			manifest_ports=$(runtime_tsv_sanitize "${CELL_CREATE_RESERVED_PORTS:-}")
+			manifest_rlimit_nofile=$(runtime_tsv_sanitize "${CELL_CREATE_RLIMIT_NOFILE:-}")
+			manifest_rlimit_as=$(runtime_tsv_sanitize "${CELL_CREATE_RLIMIT_AS:-}")
+			manifest_rlimit_core=$(runtime_tsv_sanitize "${CELL_CREATE_RLIMIT_CORE:-}")
+			manifest_depends=$(runtime_tsv_sanitize "${CELL_DEPENDS_ON:-}")
+			manifest_healthcheck=$(runtime_tsv_sanitize "${CELL_HEALTHCHECK_CMD:-}")
+			manifest_supervise=$(runtime_tsv_sanitize "${CELL_SUPERVISE_CMD:-}")
+			manifest_mounts=$(runtime_tsv_sanitize "${CELL_VOLUME_MOUNTS:-}")
+			apply_present=0
+			if [ -f "${MANIFEST_APPLY_FILE}" ]; then
+				apply_present=1
+			fi
+			printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
+			    "${cell_name}" "${manifest_autostart}" "${manifest_profile}" \
+			    "${manifest_ports}" "${manifest_rlimit_nofile}" "${manifest_rlimit_as}" \
+			    "${manifest_rlimit_core}" "${manifest_depends}" "${manifest_healthcheck}" \
+			    "${manifest_supervise}" "${manifest_mounts}" "${apply_present}" \
+			    >> "${manifest_tmp}"
+		done
+	fi
+
+	if [ -d "${CELL_DATA_DIR}" ]; then
+		for cell_conf in "${CELL_DATA_DIR}"/*/cell.conf; do
+			[ -f "${cell_conf}" ] || continue
+			cell_name=${cell_conf%/cell.conf}
+			cell_name=${cell_name##*/}
+			assert_valid_cell_name "${cell_name}"
+
+			load_cell_conf "${cell_name}"
+			rendered_root=$(runtime_tsv_sanitize "${ROOT_DIR}")
+			rendered_autostart=$(runtime_tsv_sanitize "${CELL_AUTOSTART:-NO}")
+			rendered_profile=$(runtime_tsv_sanitize "${CELL_CREATE_PROFILE:-}")
+			rendered_ports=$(runtime_tsv_sanitize "${CELL_CREATE_RESERVED_PORTS:-}")
+			rendered_rlimit_nofile=$(runtime_tsv_sanitize "${CELL_CREATE_RLIMIT_NOFILE:-}")
+			rendered_rlimit_as=$(runtime_tsv_sanitize "${CELL_CREATE_RLIMIT_AS:-}")
+			rendered_rlimit_core=$(runtime_tsv_sanitize "${CELL_CREATE_RLIMIT_CORE:-}")
+			rendered_depends=$(runtime_tsv_sanitize "${CELL_DEPENDS_ON:-}")
+			rendered_healthcheck=$(runtime_tsv_sanitize "${CELL_HEALTHCHECK_CMD:-}")
+			rendered_supervise=$(runtime_tsv_sanitize "${CELL_SUPERVISE_CMD:-}")
+			rendered_mounts=$(runtime_tsv_sanitize "${CELL_VOLUME_MOUNTS:-}")
+
+			printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
+			    "${cell_name}" "${rendered_autostart}" "${rendered_profile}" \
+			    "${rendered_ports}" "${rendered_rlimit_nofile}" "${rendered_rlimit_as}" \
+			    "${rendered_rlimit_core}" "${rendered_depends}" "${rendered_healthcheck}" \
+			    "${rendered_supervise}" "${rendered_mounts}" "${rendered_root}" \
+			    >> "${rendered_tmp}"
+		done
+	fi
+
+	if ! command -v cellctl >/dev/null 2>&1; then
+		echo "missing required tool: cellctl" >&2
+		rm -f "${rendered_tmp}" "${manifest_tmp}" "${list_raw_tmp}" "${list_tmp}" \
+		    "${stats_raw_tmp}" "${stats_tmp}" "${merged_tmp}"
+		return 1
+	fi
+
+	if ! cellctl list -T > "${list_raw_tmp}"; then
+		echo "runtime: failed to read cellctl list" >&2
+		rm -f "${rendered_tmp}" "${manifest_tmp}" "${list_raw_tmp}" "${list_tmp}" \
+		    "${stats_raw_tmp}" "${stats_tmp}" "${merged_tmp}"
+		return 1
+	fi
+
+	if ! awk -F '\t' '
+		BEGIN { OFS="\t" }
+		NR == 1 {
+			if (NF != 6 && NF != 9)
+				exit 2
+			if ($1 != "CID" || $2 != "NAME" || $3 != "REFS" ||
+			    $4 != "PROCS" || $5 != "AGE" || $6 != "ROOT")
+				exit 2
+			if (NF == 9 && ($7 != "NOFILE" || $8 != "AS" || $9 != "CORE"))
+				exit 2
+			next
+		}
+		{
+			if (NF != 6 && NF != 9)
+				exit 3
+			print $2, $1, $3, $4, $5, $6
+		}
+	' "${list_raw_tmp}" > "${list_tmp}"; then
+		echo "runtime: unexpected TSV schema from cellctl list -T" >&2
+		rm -f "${rendered_tmp}" "${manifest_tmp}" "${list_raw_tmp}" "${list_tmp}" \
+		    "${stats_raw_tmp}" "${stats_tmp}" "${merged_tmp}"
+		return 1
+	fi
+
+	if ! cellctl stats -T > "${stats_raw_tmp}"; then
+		echo "runtime: failed to read cellctl stats" >&2
+		rm -f "${rendered_tmp}" "${manifest_tmp}" "${list_raw_tmp}" "${list_tmp}" \
+		    "${stats_raw_tmp}" "${stats_tmp}" "${merged_tmp}"
+		return 1
+	fi
+
+	if ! awk -F '\t' '
+		BEGIN { OFS="\t" }
+		NR == 1 {
+			if (NF != 9 || $1 != "CID" || $2 != "NAME" || $3 != "CPU1S" ||
+			    $4 != "CPU10S" || $5 != "PROCS" || $6 != "REFS" ||
+			    $7 != "MEMORY" || $8 != "AGE" || $9 != "ROOT")
+				exit 2
+			next
+		}
+		{
+			if (NF != 9)
+				exit 3
+			print $2, $3, $4, $5, $7, $8
+		}
+	' "${stats_raw_tmp}" > "${stats_tmp}"; then
+		echo "runtime: unexpected TSV schema from cellctl stats -T" >&2
+		rm -f "${rendered_tmp}" "${manifest_tmp}" "${list_raw_tmp}" "${list_tmp}" \
+		    "${stats_raw_tmp}" "${stats_tmp}" "${merged_tmp}"
+		return 1
+	fi
+
+	awk -F '\t' \
+	    -v manifest_file="${manifest_tmp}" \
+	    -v rendered_file="${rendered_tmp}" \
+	    -v list_file="${list_tmp}" \
+	    -v stats_file="${stats_tmp}" '
+		BEGIN { OFS="\t" }
+		function sanitize(s) {
+			gsub(/[\t\r\n]/, " ", s)
+			return s
+		}
+		FILENAME == manifest_file {
+			n = $1
+			manifest[n] = 1
+			m_autostart[n] = $2
+			m_profile[n] = $3
+			m_ports[n] = $4
+			m_rlimit_nofile[n] = $5
+			m_rlimit_as[n] = $6
+			m_rlimit_core[n] = $7
+			m_depends[n] = $8
+			m_healthcheck[n] = $9
+			m_supervise[n] = $10
+			m_mounts[n] = $11
+			m_apply_present[n] = $12
+			names[n] = 1
+			next
+		}
+		FILENAME == rendered_file {
+			n = $1
+			rendered[n] = 1
+			r_autostart[n] = $2
+			r_profile[n] = $3
+			r_ports[n] = $4
+			r_rlimit_nofile[n] = $5
+			r_rlimit_as[n] = $6
+			r_rlimit_core[n] = $7
+			r_depends[n] = $8
+			r_healthcheck[n] = $9
+			r_supervise[n] = $10
+			r_mounts[n] = $11
+			rendered_root[n] = $12
+			names[n] = 1
+			next
+		}
+		FILENAME == list_file {
+			n = $1
+			running[n] = 1
+			cid[n] = $2
+			refs[n] = $3
+			procs[n] = $4
+			age[n] = $5
+			runtime_root[n] = $6
+			names[n] = 1
+			next
+		}
+		FILENAME == stats_file {
+			n = $1
+			cpu1s[n] = $2
+			cpu10s[n] = $3
+			stats_procs[n] = $4
+			memory[n] = $5
+			stats_age[n] = $6
+			names[n] = 1
+			next
+		}
+		END {
+			for (n in names) {
+				running_v = ((n in running) ? 1 : 0)
+				rendered_v = ((n in rendered) ? 1 : 0)
+				manifest_v = ((n in manifest) ? 1 : 0)
+				apply_present_v = m_apply_present[n]
+				if (apply_present_v == "")
+					apply_present_v = 0
+
+				autostart_v = m_autostart[n]
+				if (autostart_v == "")
+					autostart_v = r_autostart[n]
+				if (autostart_v == "")
+					autostart_v = "NO"
+
+				desired_state_v = (autostart_v == "YES") ? 1 : 0
+
+				profile_v = m_profile[n]
+				if (profile_v == "")
+					profile_v = r_profile[n]
+
+				ports_v = m_ports[n]
+				if (ports_v == "")
+					ports_v = r_ports[n]
+
+				rlimit_nofile_v = m_rlimit_nofile[n]
+				if (rlimit_nofile_v == "")
+					rlimit_nofile_v = r_rlimit_nofile[n]
+				if (rlimit_nofile_v == "")
+					rlimit_nofile_v = "unlimited"
+
+				rlimit_as_v = m_rlimit_as[n]
+				if (rlimit_as_v == "")
+					rlimit_as_v = r_rlimit_as[n]
+				if (rlimit_as_v == "")
+					rlimit_as_v = "unlimited"
+
+				rlimit_core_v = m_rlimit_core[n]
+				if (rlimit_core_v == "")
+					rlimit_core_v = r_rlimit_core[n]
+				if (rlimit_core_v == "")
+					rlimit_core_v = "unlimited"
+
+				depends_v = m_depends[n]
+				if (depends_v == "")
+					depends_v = r_depends[n]
+
+				healthcheck_v = m_healthcheck[n]
+				if (healthcheck_v == "")
+					healthcheck_v = r_healthcheck[n]
+
+				supervise_v = m_supervise[n]
+				if (supervise_v == "")
+					supervise_v = r_supervise[n]
+
+				mounts_v = m_mounts[n]
+				if (mounts_v == "")
+					mounts_v = r_mounts[n]
+
+				procs_v = procs[n]
+				if (stats_procs[n] != "") {
+					procs_v = stats_procs[n]
+				}
+
+				age_v = age[n]
+				if (stats_age[n] != "") {
+					age_v = stats_age[n]
+				}
+
+				root_v = runtime_root[n]
+				if (root_v == "") {
+					root_v = rendered_root[n]
+				}
+
+				print sanitize(n), running_v, desired_state_v, sanitize(cid[n]), \
+				    sanitize(refs[n]), sanitize(procs_v), sanitize(cpu1s[n]), \
+				    sanitize(cpu10s[n]), sanitize(memory[n]), sanitize(age_v), \
+				    sanitize(root_v), sanitize(autostart_v), sanitize(profile_v), \
+				    sanitize(ports_v), sanitize(rlimit_nofile_v), \
+				    sanitize(rlimit_as_v), sanitize(rlimit_core_v), \
+				    sanitize(depends_v), sanitize(healthcheck_v), \
+				    sanitize(supervise_v), sanitize(mounts_v), manifest_v, \
+				    rendered_v, apply_present_v
+			}
+		}
+	' "${manifest_tmp}" "${rendered_tmp}" "${list_tmp}" "${stats_tmp}" > "${merged_tmp}"
+
+	LC_ALL=C sort -k1,1 "${merged_tmp}" > "${out_file}"
+
+	rm -f "${rendered_tmp}" "${manifest_tmp}" "${list_raw_tmp}" "${list_tmp}" \
+	    "${stats_raw_tmp}" "${stats_tmp}" "${merged_tmp}"
+	return 0
+}
+
+runtime_list() {
+	header=YES
+	tsv=NO
+	view=merged
+	output_fields=
+
+	while [ $# -gt 0 ]; do
+		case "$1" in
+		--view)
+			[ $# -ge 2 ] || {
+				echo "cell list: --view requires a value" >&2
+				exit 1
+			}
+			view=$2
+			shift 2
+			;;
+		-o)
+			[ $# -ge 2 ] || {
+				echo "cell list: -o requires a field list" >&2
+				exit 1
+			}
+			output_fields=$2
+			shift 2
+			;;
+		-T)
+			tsv=YES
+			shift
+			;;
+		-H)
+			header=NO
+			shift
+			;;
+		-*)
+			echo "cell list: unknown option $1" >&2
+			exit 1
+			;;
+		*)
+			echo "cell list: unexpected argument $1" >&2
+			exit 1
+			;;
+		esac
+	done
+	if [ "${header}" = "NO" ] && [ "${tsv}" != "YES" ]; then
+		echo "cell list: -H requires -T" >&2
+		exit 1
+	fi
+
+	runtime_parse_output_fields "${output_fields}" "${view}" || exit 1
+	snapshot_tmp=$(mktemp /tmp/cellmgr-runtime-snapshot.XXXXXX)
+	projected_tmp=$(mktemp /tmp/cellmgr-runtime-projected.XXXXXX)
+	if ! runtime_collect_snapshot "${snapshot_tmp}"; then
+		rm -f "${snapshot_tmp}" "${projected_tmp}"
+		exit 1
+	fi
+	runtime_project_fields "${snapshot_tmp}" > "${projected_tmp}"
+
+	if [ "${tsv}" = "YES" ]; then
+		if [ "${header}" = "YES" ]; then
+			runtime_print_header
+		fi
+		cat "${projected_tmp}"
+	else
+		runtime_print_human_table "${projected_tmp}"
+	fi
+
+	rm -f "${snapshot_tmp}" "${projected_tmp}"
+}
+
+runtime_show() {
+	[ $# -ge 1 ] || {
+		echo "cell show: missing cell name" >&2
+		exit 1
+	}
+	target_name=$1
+	shift
+	assert_valid_cell_name "${target_name}"
+
+	header=YES
+	tsv=NO
+	view=merged
+	output_fields=
+
+	while [ $# -gt 0 ]; do
+		case "$1" in
+		--view)
+			[ $# -ge 2 ] || {
+				echo "cell show: --view requires a value" >&2
+				exit 1
+			}
+			view=$2
+			shift 2
+			;;
+		-o)
+			[ $# -ge 2 ] || {
+				echo "cell show: -o requires a field list" >&2
+				exit 1
+			}
+			output_fields=$2
+			shift 2
+			;;
+		-T)
+			tsv=YES
+			shift
+			;;
+		-H)
+			header=NO
+			shift
+			;;
+		-*)
+			echo "cell show: unknown option $1" >&2
+			exit 1
+			;;
+		*)
+			echo "cell show: unexpected argument $1" >&2
+			exit 1
+			;;
+		esac
+	done
+	if [ "${header}" = "NO" ] && [ "${tsv}" != "YES" ]; then
+		echo "cell show: -H requires -T" >&2
+		exit 1
+	fi
+
+	runtime_parse_output_fields "${output_fields}" "${view}" || exit 1
+	snapshot_tmp=$(mktemp /tmp/cellmgr-runtime-snapshot.XXXXXX)
+	row_tmp=$(mktemp /tmp/cellmgr-runtime-row.XXXXXX)
+	projected_tmp=$(mktemp /tmp/cellmgr-runtime-projected.XXXXXX)
+
+	if ! runtime_collect_snapshot "${snapshot_tmp}"; then
+		rm -f "${snapshot_tmp}" "${row_tmp}" "${projected_tmp}"
+		exit 1
+	fi
+
+	if ! awk -F '\t' -v n="${target_name}" '$1==n{print;found=1;exit} END{exit found?0:1}' \
+	    "${snapshot_tmp}" > "${row_tmp}"; then
+		echo "cell not found: ${target_name}" >&2
+		rm -f "${snapshot_tmp}" "${row_tmp}" "${projected_tmp}"
+		exit 1
+	fi
+	runtime_project_fields "${row_tmp}" > "${projected_tmp}"
+
+	if [ "${tsv}" = "YES" ]; then
+		if [ "${header}" = "YES" ]; then
+			runtime_print_header
+		fi
+		cat "${projected_tmp}"
+	else
+		runtime_print_human_table "${projected_tmp}"
+	fi
+
+	rm -f "${snapshot_tmp}" "${row_tmp}" "${projected_tmp}"
+}
+
+runtime_fields() {
+	view=merged
+	tsv=NO
+	header=YES
+	while [ $# -gt 0 ]; do
+		case "$1" in
+		--view)
+			[ $# -ge 2 ] || {
+				echo "cell fields: --view requires a value" >&2
+				exit 1
+			}
+			view=$2
+			shift 2
+			;;
+		-T)
+			tsv=YES
+			shift
+			;;
+		-H)
+			header=NO
+			shift
+			;;
+		-*)
+			echo "cell fields: unknown option $1" >&2
+			exit 1
+			;;
+		*)
+			echo "cell fields: unexpected argument $1" >&2
+			exit 1
+			;;
+		esac
+	done
+	if [ "${header}" = "NO" ] && [ "${tsv}" != "YES" ]; then
+		echo "cell fields: -H requires -T" >&2
+		exit 1
+	fi
+	fields_tmp=$(mktemp /tmp/cellmgr-runtime-fields.XXXXXX)
+	runtime_supported_fields "${view}" > "${fields_tmp}" || {
+		rm -f "${fields_tmp}"
+		exit 1
+	}
+	if [ "${tsv}" = "YES" ]; then
+		if [ "${header}" = "YES" ]; then
+			printf 'field\n'
+		fi
+		cat "${fields_tmp}"
+	else
+		printf '%-24s\n' 'FIELD'
+		awk '{ printf "%-24s\n", $0 }' "${fields_tmp}"
+	fi
+	rm -f "${fields_tmp}"
+}
+
+runtime_shell() {
+	need_root
+	name=$1
+	assert_valid_cell_name "${name}"
+	if ! command -v cellctl >/dev/null 2>&1; then
+		echo "missing required tool: cellctl" >&2
+		exit 1
+	fi
+	cellctl exec "${name}" /bin/sh
+}
+
+volume_used_by_list() {
+	volume_name=$1
+	used_by=
+
+	if ensure_manifest_layout; then
+		for cell_conf in "${MANIFEST_DIR}"/*.cell; do
+			[ -f "${cell_conf}" ] || continue
+			cell_name=${cell_conf##*/}
+			cell_name=${cell_name%.cell}
+			CELL_VOLUME_MOUNTS=
+			# shellcheck disable=SC1090
+			. "${cell_conf}"
+			for spec in $(normalize_volume_mount_list "${CELL_VOLUME_MOUNTS:-}"); do
+				if ! parse_volume_mount_spec "${spec}" "volume used_by"; then
+					continue
+				fi
+				if [ "${MOUNT_VOLUME}" = "${volume_name}" ]; then
+					if ! word_list_contains "${cell_name}" "${used_by}"; then
+						used_by="${used_by} ${cell_name}"
+					fi
+					break
+				fi
+			done
+		done
+	fi
+
+	printf '%s\n' "${used_by# }" | tr ' ' ','
+}
+
+volume_supported_fields() {
+	view=${1:-merged}
+	case "${view}" in
+	desired)
+		cat <<FIELDS
+name
+manifest
+mode
+refs
+used_by
+FIELDS
+		;;
+	runtime)
+		cat <<FIELDS
+name
+runtime
+path
+mounted
+refs
+used_by
+FIELDS
+		;;
+	merged)
+		cat <<FIELDS
+name
+manifest
+runtime
+mode
+path
+mounted
+refs
+used_by
+FIELDS
+		;;
+	*)
+		echo "volume: invalid view '${view}' (expected merged|desired|runtime)" >&2
+		return 1
+		;;
+	esac
+}
+
+volume_view_default_fields() {
+	case "${1:-merged}" in
+	desired)
+		printf '%s\n' 'name,manifest,mode,refs,used_by'
+		;;
+	runtime)
+		printf '%s\n' 'name,runtime,path,mounted,refs,used_by'
+		;;
+	merged)
+		printf '%s\n' 'name,manifest,runtime,refs,mounted,mode,path,used_by'
+		;;
+	*)
+		echo "volume: invalid view '${1}' (expected merged|desired|runtime)" >&2
+		return 1
+		;;
+	esac
+}
+
+volume_field_allowed() {
+	view=$1
+	field=$2
+	case "${view}:${field}" in
+	merged:*)
+		return 0
+		;;
+	desired:name|desired:manifest|desired:mode|desired:refs|desired:used_by)
+		return 0
+		;;
+	runtime:name|runtime:runtime|runtime:path|runtime:mounted|runtime:refs|runtime:used_by)
+		return 0
+		;;
+	*)
+		return 1
+		;;
+	esac
+}
+
+volume_field_index() {
+	case "$1" in
+	name) printf '1\n' ;;
+	manifest) printf '2\n' ;;
+	runtime) printf '3\n' ;;
+	mode) printf '4\n' ;;
+	path) printf '5\n' ;;
+	mounted) printf '6\n' ;;
+	refs) printf '7\n' ;;
+	used_by) printf '8\n' ;;
+	*)
+		return 1
+		;;
+	esac
+}
+
+volume_parse_output_fields() {
+	requested=${1:-}
+	view=${2:-merged}
+	if [ -z "${requested}" ]; then
+		requested=$(volume_view_default_fields "${view}") || return 1
+	fi
+
+	VOLUME_OUTPUT_FIELDS=
+	VOLUME_OUTPUT_CUT=
+	for field in $(printf '%s' "${requested}" | tr ',' ' '); do
+		case "${field}" in
+		*[!a-z0-9_]*|'')
+			echo "volume: invalid field token '${field}'" >&2
+			return 1
+			;;
+		esac
+		if ! volume_field_allowed "${view}" "${field}"; then
+			echo "volume: field '${field}' is not available in view '${view}'" >&2
+			return 1
+		fi
+		if ! idx=$(volume_field_index "${field}"); then
+			echo "volume: unknown field '${field}'" >&2
+			return 1
+		fi
+		if [ -z "${VOLUME_OUTPUT_FIELDS}" ]; then
+			VOLUME_OUTPUT_FIELDS=${field}
+			VOLUME_OUTPUT_CUT=${idx}
+		else
+			VOLUME_OUTPUT_FIELDS="${VOLUME_OUTPUT_FIELDS} ${field}"
+			VOLUME_OUTPUT_CUT="${VOLUME_OUTPUT_CUT},${idx}"
+		fi
+	done
+
+	if [ -z "${VOLUME_OUTPUT_FIELDS}" ]; then
+		echo "volume: field list is empty" >&2
+		return 1
+	fi
+}
+
+volume_print_header() {
+	line=
+	for field in ${VOLUME_OUTPUT_FIELDS}; do
+		if [ -z "${line}" ]; then
+			line=${field}
+		else
+			line=$(printf '%s\t%s' "${line}" "${field}")
+		fi
+	done
+	printf '%s\n' "${line}"
+}
+
+volume_project_fields() {
+	in_file=$1
+	awk -F '\t' -v cols="${VOLUME_OUTPUT_CUT}" '
+		BEGIN {
+			OFS="\t"
+			n = split(cols, idx, ",")
+		}
+		{
+			for (i = 1; i <= n; i++) {
+				field_no = idx[i] + 0
+				value = ""
+				if (field_no >= 1 && field_no <= NF)
+					value = $(field_no)
+				if (i == 1)
+					out = value
+				else
+					out = out OFS value
+			}
+			print out
+		}
+	' "${in_file}"
+}
+
+volume_print_human_table() {
+	in_file=$1
+	awk -F '\t' -v cols="${VOLUME_OUTPUT_FIELDS}" '
+		function is_bool_field(f) {
+			return (f == "manifest" || f == "runtime" || f == "mounted")
+		}
+		function humanize(f, v) {
+			if (is_bool_field(f)) {
+				if (v == "1")
+					return "YES"
+				if (v == "0")
+					return "NO"
+			}
+			if (v == "")
+				return "-"
+			return v
+		}
+		BEGIN {
+			n = split(cols, names, " ")
+			for (i = 1; i <= n; i++) {
+				headers[i] = toupper(names[i])
+				width[i] = length(headers[i])
+			}
+		}
+		{
+			rows = NR
+			for (i = 1; i <= n; i++) {
+				val = humanize(names[i], $i)
+				cell[NR, i] = val
+				if (length(val) > width[i])
+					width[i] = length(val)
+			}
+		}
+		END {
+			for (i = 1; i <= n; i++) {
+				printf "%-*s", width[i], headers[i]
+				if (i < n)
+					printf "  "
+				else
+					printf "\n"
+			}
+			for (r = 1; r <= rows; r++) {
+				for (i = 1; i <= n; i++) {
+					printf "%-*s", width[i], cell[r, i]
+					if (i < n)
+						printf "  "
+					else
+						printf "\n"
+				}
+			}
+		}
+	' "${in_file}"
+}
+
+volume_collect_snapshot() {
+	out_file=$1
+	raw_tmp=$(mktemp /tmp/cellmgr-volume-raw.XXXXXX)
+	names=
+
+	if ensure_volume_manifest_layout; then
+		for volume_conf in "${MANIFEST_DIR}"/*.volume; do
+			[ -f "${volume_conf}" ] || continue
+			name=${volume_conf##*/}
+			name=${name%.volume}
+			assert_valid_volume_name "${name}"
+			names="${names} ${name}"
+		done
+	fi
+
+	if [ -d "${CELL_VOLUME_DIR}" ]; then
+		for volume_path in "${CELL_VOLUME_DIR}"/*; do
+			[ -d "${volume_path}" ] || continue
+			name=${volume_path##*/}
+			case "${name}" in
+			*[!A-Za-z0-9._-]*)
+				echo "Skipping invalid runtime volume directory ${volume_path}" >&2
+				continue
+				;;
+			esac
+			if ! word_list_contains "${name}" "${names}"; then
+				names="${names} ${name}"
+			fi
+		done
+	fi
+
+	: > "${raw_tmp}"
+	for name in ${names}; do
+		volume_manifest_paths "${name}"
+		manifest=0
+		runtime=0
+		mounted=0
+		mode=
+		if [ -f "${VOLUME_CONF}" ]; then
+			manifest=1
+			load_volume_manifest_conf "${name}"
+			mode=$(runtime_tsv_sanitize "${VOLUME_MODE:-}")
+		fi
+		path=$(runtime_tsv_sanitize "${VOLUME_PATH}")
+		if [ -d "${VOLUME_PATH}" ]; then
+			runtime=1
+			if runtime_volume_mounted "${VOLUME_PATH}"; then
+				mounted=1
+			fi
+		fi
+		refs=$(volume_ref_count "${name}")
+		used_by=$(runtime_tsv_sanitize "$(volume_used_by_list "${name}")")
+		printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
+		    "${name}" "${manifest}" "${runtime}" "${mode}" "${path}" \
+		    "${mounted}" "${refs}" "${used_by}" >> "${raw_tmp}"
+	done
+
+	LC_ALL=C sort -k1,1 "${raw_tmp}" > "${out_file}"
+	rm -f "${raw_tmp}"
+}
+
+volume_list_view() {
+	header=YES
+	tsv=NO
+	view=merged
+	output_fields=
+
+	while [ $# -gt 0 ]; do
+		case "$1" in
+		--view)
+			[ $# -ge 2 ] || {
+				echo "volume list: --view requires a value" >&2
+				exit 1
+			}
+			view=$2
+			shift 2
+			;;
+		-o)
+			[ $# -ge 2 ] || {
+				echo "volume list: -o requires a field list" >&2
+				exit 1
+			}
+			output_fields=$2
+			shift 2
+			;;
+		-T)
+			tsv=YES
+			shift
+			;;
+		-H)
+			header=NO
+			shift
+			;;
+		-*)
+			echo "volume list: unknown option $1" >&2
+			exit 1
+			;;
+		*)
+			echo "volume list: unexpected argument $1" >&2
+			exit 1
+			;;
+		esac
+	done
+	if [ "${header}" = "NO" ] && [ "${tsv}" != "YES" ]; then
+		echo "volume list: -H requires -T" >&2
+		exit 1
+	fi
+	volume_parse_output_fields "${output_fields}" "${view}" || exit 1
+	snapshot_tmp=$(mktemp /tmp/cellmgr-volume-snapshot.XXXXXX)
+	projected_tmp=$(mktemp /tmp/cellmgr-volume-projected.XXXXXX)
+	volume_collect_snapshot "${snapshot_tmp}"
+	volume_project_fields "${snapshot_tmp}" > "${projected_tmp}"
+
+	if [ "${tsv}" = "YES" ]; then
+		if [ "${header}" = "YES" ]; then
+			volume_print_header
+		fi
+		cat "${projected_tmp}"
+	else
+		volume_print_human_table "${projected_tmp}"
+	fi
+
+	rm -f "${snapshot_tmp}" "${projected_tmp}"
+}
+
+volume_show_view() {
+	[ $# -ge 1 ] || {
+		echo "volume show: missing volume name" >&2
+		exit 1
+	}
+	name=$1
+	shift
+	assert_valid_volume_name "${name}"
+
+	header=YES
+	tsv=NO
+	view=merged
+	output_fields=
+	while [ $# -gt 0 ]; do
+		case "$1" in
+		--view)
+			[ $# -ge 2 ] || {
+				echo "volume show: --view requires a value" >&2
+				exit 1
+			}
+			view=$2
+			shift 2
+			;;
+		-o)
+			[ $# -ge 2 ] || {
+				echo "volume show: -o requires a field list" >&2
+				exit 1
+			}
+			output_fields=$2
+			shift 2
+			;;
+		-T)
+			tsv=YES
+			shift
+			;;
+		-H)
+			header=NO
+			shift
+			;;
+		-*)
+			echo "volume show: unknown option $1" >&2
+			exit 1
+			;;
+		*)
+			echo "volume show: unexpected argument $1" >&2
+			exit 1
+			;;
+		esac
+	done
+	if [ "${header}" = "NO" ] && [ "${tsv}" != "YES" ]; then
+		echo "volume show: -H requires -T" >&2
+		exit 1
+	fi
+
+	volume_parse_output_fields "${output_fields}" "${view}" || exit 1
+	snapshot_tmp=$(mktemp /tmp/cellmgr-volume-snapshot.XXXXXX)
+	row_tmp=$(mktemp /tmp/cellmgr-volume-row.XXXXXX)
+	projected_tmp=$(mktemp /tmp/cellmgr-volume-projected.XXXXXX)
+	volume_collect_snapshot "${snapshot_tmp}"
+	if ! awk -F '\t' -v n="${name}" '$1==n{print;found=1;exit} END{exit found?0:1}' \
+	    "${snapshot_tmp}" > "${row_tmp}"; then
+		echo "volume not found: ${name}" >&2
+		rm -f "${snapshot_tmp}" "${row_tmp}" "${projected_tmp}"
+		exit 1
+	fi
+	volume_project_fields "${row_tmp}" > "${projected_tmp}"
+
+	if [ "${tsv}" = "YES" ]; then
+		if [ "${header}" = "YES" ]; then
+			volume_print_header
+		fi
+		cat "${projected_tmp}"
+	else
+		volume_print_human_table "${projected_tmp}"
+	fi
+
+	rm -f "${snapshot_tmp}" "${row_tmp}" "${projected_tmp}"
+}
+
+volume_fields_view() {
+	view=merged
+	tsv=NO
+	header=YES
+	while [ $# -gt 0 ]; do
+		case "$1" in
+		--view)
+			[ $# -ge 2 ] || {
+				echo "volume fields: --view requires a value" >&2
+				exit 1
+			}
+			view=$2
+			shift 2
+			;;
+		-T)
+			tsv=YES
+			shift
+			;;
+		-H)
+			header=NO
+			shift
+			;;
+		-*)
+			echo "volume fields: unknown option $1" >&2
+			exit 1
+			;;
+		*)
+			echo "volume fields: unexpected argument $1" >&2
+			exit 1
+			;;
+		esac
+	done
+	if [ "${header}" = "NO" ] && [ "${tsv}" != "YES" ]; then
+		echo "volume fields: -H requires -T" >&2
+		exit 1
+	fi
+
+	fields_tmp=$(mktemp /tmp/cellmgr-volume-fields.XXXXXX)
+	volume_supported_fields "${view}" > "${fields_tmp}" || {
+		rm -f "${fields_tmp}"
+		exit 1
+	}
+	if [ "${tsv}" = "YES" ]; then
+		if [ "${header}" = "YES" ]; then
+			printf 'field\n'
+		fi
+		cat "${fields_tmp}"
+	else
+		printf '%-24s\n' 'FIELD'
+		awk '{ printf "%-24s\n", $0 }' "${fields_tmp}"
+	fi
+	rm -f "${fields_tmp}"
+}
+
+emit_reconcile_section() {
+	emit_section=$1
+	if [ "${RECONCILE_LAST_SECTION:-}" != "${emit_section}" ]; then
+		if [ -n "${RECONCILE_LAST_SECTION:-}" ]; then
+			printf '\n'
+		fi
+		printf '%s\n' "${emit_section}"
+		RECONCILE_LAST_SECTION=${emit_section}
+	fi
+}
+
+emit_reconcile_section_action() {
+	emit_section=$1
+	emit_action=$2
+	emit_msg=${3:-}
+	if [ "${RECONCILE_SILENT}" = "YES" ]; then
+		return
+	fi
+	emit_reconcile_section "${emit_section}"
+	printf '  %-12s %s\n' "${emit_action}" "${emit_msg}"
+}
+
+emit_reconcile() {
+	emit_name=$1
+	emit_action=$2
+	emit_msg=${3:-}
+	emit_reconcile_section_action "cell ${emit_name}" "${emit_action}" "${emit_msg}"
+}
+
+emit_reconcile_header() {
+	dry_run=$1
+	reapply=$2
+	restart_changed=$3
+	verbose=$4
+	if [ "${RECONCILE_SILENT}" = "YES" ]; then
+		return
+	fi
+	printf 'apply: dry-run=%s reapply=%s restart-changed=%s verbose=%s\n' \
+	    "${dry_run}" "${reapply}" "${restart_changed}" "${verbose}"
+}
+
+emit_reconcile_footer() {
+	total=$1
+	changed=$2
+	failed=$3
+	dry_run=$4
+	if [ "${RECONCILE_SILENT}" = "YES" ]; then
+		return
+	fi
+	printf '\n'
+	printf 'summary: cells=%s changed=%s failed=%s dry-run=%s\n' \
+	    "${total}" "${changed}" "${failed}" "${dry_run}"
+}
+
+emit_reconcile_result() {
+	emit_name=$1
+	emit_status=$2
+	emit_msg=${3:-}
+	emit_reconcile_section_action "cell ${emit_name}" "${emit_status}" "${emit_msg}"
+}
+
+run_reconcile_step() {
+	step_label=$1
+	shift
+	if [ "${RECONCILE_VERBOSE}" = "YES" ]; then
+		printf '    %s\n' "${step_label}"
+		"$@"
+		rc=$?
+		if [ "${rc}" -ne 0 ]; then
+			printf '    failed: %s (exit %s)\n' "${step_label}" "${rc}" >&2
+		fi
+		return "${rc}"
+	fi
+
+	step_log=$(mktemp /tmp/cellmgr-reconcile.XXXXXX)
+	if "$@" >"${step_log}" 2>&1; then
+		rm -f "${step_log}"
+		return 0
+	fi
+	rc=$?
+	if [ -s "${step_log}" ]; then
+		printf '    failed: %s\n' "${step_label}" >&2
+		cat "${step_log}" >&2
+	else
+		printf '    failed: %s (exit %s)\n' "${step_label}" "${rc}" >&2
+	fi
+	rm -f "${step_log}"
+	return "${rc}"
+}
+
+word_list_contains() {
+	needle=$1
+	list=$2
+	for item in ${list}; do
+		if [ "${item}" = "${needle}" ]; then
+			return 0
+		fi
+	done
+	return 1
+}
+
+reconcile_order() {
+	if ! ensure_manifest_layout; then
+		return 0
+	fi
+	pending=
+	for cell_conf in "${MANIFEST_DIR}"/*.cell; do
+		[ -f "${cell_conf}" ] || continue
+		cell_name=${cell_conf##*/}
+		cell_name=${cell_name%.cell}
+		assert_valid_cell_name "${cell_name}"
+		pending="${pending} ${cell_name}"
+	done
+
+	set -- ${pending}
+	if [ $# -eq 0 ]; then
+		return 0
+	fi
+
+	done_names=
+	ordered=
+	while :; do
+		set -- ${pending}
+		if [ $# -eq 0 ]; then
+			break
+		fi
+
+		progress=0
+		remaining=
+		for cell_name in "$@"; do
+			load_manifest_cell_conf "${cell_name}"
+			deps=$(normalize_dep_list "${CELL_DEPENDS_ON:-}")
+			ready=YES
+			for dep in ${deps}; do
+				if ! manifest_cell_exists "${dep}"; then
+					echo "cell ${cell_name} depends on missing manifest cell ${dep}" >&2
+					return 1
+				fi
+				if ! word_list_contains "${dep}" "${done_names}"; then
+					ready=NO
+					break
+				fi
+			done
+
+			if [ "${ready}" = "YES" ]; then
+				ordered="${ordered} ${cell_name}"
+				done_names="${done_names} ${cell_name}"
+				progress=1
+			else
+				remaining="${remaining} ${cell_name}"
+			fi
+		done
+
+		if [ "${progress}" -eq 0 ]; then
+			echo "dependency cycle detected among:${remaining}" >&2
+			return 1
+		fi
+		pending=${remaining}
+	done
+
+	for name in ${ordered}; do
+		printf '%s\n' "${name}"
+	done
+}
+
+healthcheck_cell() {
+	name=$1
+	health_cmd=$2
+	[ -n "${health_cmd}" ] || return 0
+
+	cell_cid=$(cell_cid_by_name "${name}" || true)
+	if [ -z "${cell_cid}" ]; then
+		echo "healthcheck: cell ${name} is not running" >&2
+		return 1
+	fi
+
+	cellctl exec "${cell_cid}" /bin/sh -c "${health_cmd}"
+}
+
+reconcile_one_cell() {
+	name=$1
+	dry_run=$2
+	reapply=$3
+	restart_changed=$4
+
+	load_manifest_cell_conf "${name}"
+	manifest_autostart=${CELL_AUTOSTART:-NO}
+	manifest_supervise_cmd=${CELL_SUPERVISE_CMD:-}
+	manifest_create_profile=${CELL_CREATE_PROFILE:-}
+	manifest_create_reserved_ports=${CELL_CREATE_RESERVED_PORTS:-}
+	manifest_create_rlimit_nofile=${CELL_CREATE_RLIMIT_NOFILE:-}
+	manifest_create_rlimit_as=${CELL_CREATE_RLIMIT_AS:-}
+	manifest_create_rlimit_core=${CELL_CREATE_RLIMIT_CORE:-}
+	manifest_supervise_facility=${CELL_SUPERVISE_FACILITY:-}
+	manifest_supervise_stdout_level=${CELL_SUPERVISE_STDOUT_LEVEL:-}
+	manifest_supervise_stderr_level=${CELL_SUPERVISE_STDERR_LEVEL:-}
+	manifest_supervise_tag=${CELL_SUPERVISE_TAG:-}
+	manifest_depends_on=${CELL_DEPENDS_ON:-}
+	manifest_healthcheck_cmd=${CELL_HEALTHCHECK_CMD:-}
+	manifest_volume_mounts=${CELL_VOLUME_MOUNTS:-}
+
+	cell_paths "${name}"
+	manifest_hash=$(file_hash "${MANIFEST_CELL_CONF}")
+	manifest_hash_file="${STATE_DIR}/manifest.sha256"
+	apply_hash_file="${STATE_DIR}/apply.sha256"
+	runtime_exists=NO
+	config_changed=NO
+	policy_changed=NO
+	service_changed=NO
+	changed=0
+
+	if [ -r "${CELL_CONF}" ]; then
+		runtime_exists=YES
+		load_cell_conf "${name}"
+		if [ "${CELL_AUTOSTART:-NO}" != "${manifest_autostart}" ] ||
+		   [ "${CELL_SUPERVISE_CMD:-}" != "${manifest_supervise_cmd}" ] ||
+		   [ "${CELL_SUPERVISE_FACILITY:-}" != "${manifest_supervise_facility}" ] ||
+		   [ "${CELL_SUPERVISE_STDOUT_LEVEL:-}" != "${manifest_supervise_stdout_level}" ] ||
+		   [ "${CELL_SUPERVISE_STDERR_LEVEL:-}" != "${manifest_supervise_stderr_level}" ] ||
+		   [ "${CELL_SUPERVISE_TAG:-}" != "${manifest_supervise_tag}" ] ||
+		   [ "${CELL_DEPENDS_ON:-}" != "${manifest_depends_on}" ] ||
+		   [ "${CELL_HEALTHCHECK_CMD:-}" != "${manifest_healthcheck_cmd}" ] ||
+		   [ "${CELL_VOLUME_MOUNTS:-}" != "${manifest_volume_mounts}" ]; then
+			config_changed=YES
+			service_changed=YES
+		fi
+		if [ "${CELL_CREATE_PROFILE:-}" != "${manifest_create_profile}" ] ||
+		   [ "${CELL_CREATE_RESERVED_PORTS:-}" != "${manifest_create_reserved_ports}" ] ||
+		   [ "${CELL_CREATE_RLIMIT_NOFILE:-}" != "${manifest_create_rlimit_nofile}" ] ||
+		   [ "${CELL_CREATE_RLIMIT_AS:-}" != "${manifest_create_rlimit_as}" ] ||
+		   [ "${CELL_CREATE_RLIMIT_CORE:-}" != "${manifest_create_rlimit_core}" ]; then
+			config_changed=YES
+			policy_changed=YES
+		fi
+	fi
+
+	running=NO
+	if cell_exists "${name}"; then
+		running=YES
+	fi
+
+	apply_needed=NO
+	apply_hash=
+	if [ -r "${MANIFEST_APPLY_FILE}" ]; then
+		apply_hash=$(file_hash "${MANIFEST_APPLY_FILE}")
+		prev_apply_hash=$(state_read "${apply_hash_file}")
+		if [ "${reapply}" = "YES" ] || [ "${apply_hash}" != "${prev_apply_hash}" ]; then
+			apply_needed=YES
+		fi
+	fi
+
+	if [ "${runtime_exists}" = "NO" ]; then
+		emit_reconcile "${name}" "CREATE" "render runtime cell state"
+		changed=1
+	elif [ "${config_changed}" = "YES" ]; then
+		emit_reconcile "${name}" "UPDATE" "reconcile runtime cell.conf"
+		changed=1
+	fi
+
+	if [ "${manifest_autostart}" = "YES" ]; then
+		if [ "${apply_needed}" = "YES" ]; then
+			if [ "${running}" = "YES" ]; then
+				emit_reconcile "${name}" "QUIESCE" "pause supervised service for apply"
+				emit_reconcile "${name}" "APPLY" "run ${MANIFEST_APPLY_FILE}"
+				emit_reconcile "${name}" "RESTART" "supervised service after apply"
+			else
+				emit_reconcile "${name}" "APPLY" "run ${MANIFEST_APPLY_FILE}"
+				emit_reconcile "${name}" "START" "supervised service after apply"
+			fi
+			changed=1
+		elif [ "${running}" = "NO" ]; then
+			emit_reconcile "${name}" "START" "autostart=YES"
+			changed=1
+		elif [ "${service_changed}" = "YES" ]; then
+			emit_reconcile "${name}" "RESTART" "service settings changed"
+			changed=1
+		elif [ "${policy_changed}" = "YES" ] && [ "${restart_changed}" = "YES" ]; then
+			emit_reconcile "${name}" "RESTART" "policy changed (--restart-changed)"
+			changed=1
+		elif [ "${policy_changed}" = "YES" ]; then
+			emit_reconcile "${name}" "WARN" "policy drift requires restart or --restart-changed"
+		fi
+	else
+		if [ "${running}" = "YES" ]; then
+			emit_reconcile "${name}" "STOP" "autostart=NO"
+			changed=1
+		fi
+		if [ "${apply_needed}" = "YES" ]; then
+			emit_reconcile "${name}" "APPLY" "run ${MANIFEST_APPLY_FILE}"
+			changed=1
+		fi
+	fi
+
+	if [ -n "${manifest_healthcheck_cmd}" ] && [ "${manifest_autostart}" = "YES" ]; then
+		emit_reconcile "${name}" "HEALTHCHECK" "${manifest_healthcheck_cmd}"
+	fi
+
+	if [ "${changed}" -eq 0 ]; then
+		emit_reconcile "${name}" "NOOP" "already converged"
+	fi
+
+	if [ "${dry_run}" = "YES" ]; then
+		if [ "${changed}" -ne 0 ]; then
+			emit_reconcile_result "${name}" "DRY-RUN" "changes pending"
+			return 2
+		fi
+		emit_reconcile_result "${name}" "DRY-RUN" "already converged"
+		return 0
+	fi
+
+	if [ "${runtime_exists}" = "NO" ]; then
+		if ! run_reconcile_step "create runtime state" create_cell "${name}" "${manifest_autostart}" "${manifest_supervise_cmd}" \
+		    "${manifest_create_profile}" "${manifest_create_reserved_ports}" \
+		    "${manifest_create_rlimit_nofile}" "${manifest_create_rlimit_as}" \
+		    "${manifest_create_rlimit_core}" \
+		    "${manifest_supervise_facility}" "${manifest_supervise_stdout_level}" \
+		    "${manifest_supervise_stderr_level}" "${manifest_supervise_tag}" \
+		    "${manifest_depends_on}" "${manifest_healthcheck_cmd}" \
+		    "${manifest_volume_mounts}"; then
+			state_write "${STATE_DIR}/last_reconcile_result" "error:create"
+			emit_reconcile_result "${name}" "FAILED" "create"
+			return 1
+		fi
+		state_write "${manifest_hash_file}" "${manifest_hash}"
+	elif [ "${config_changed}" = "YES" ]; then
+		mkdir -p "${STATE_DIR}"
+		if ! write_runtime_cell_conf "${name}" "${manifest_autostart}" \
+		    "${manifest_supervise_cmd}" "${manifest_create_profile}" \
+		    "${manifest_create_reserved_ports}" "${manifest_create_rlimit_nofile}" \
+		    "${manifest_create_rlimit_as}" "${manifest_create_rlimit_core}" \
+		    "${manifest_supervise_facility}" \
+		    "${manifest_supervise_stdout_level}" "${manifest_supervise_stderr_level}" \
+		    "${manifest_supervise_tag}" "${manifest_depends_on}" \
+		    "${manifest_healthcheck_cmd}" "${manifest_volume_mounts}"; then
+			state_write "${STATE_DIR}/last_reconcile_result" "error:render"
+			return 1
+		fi
+		state_write "${manifest_hash_file}" "${manifest_hash}"
+	fi
+
+	if [ "${manifest_autostart}" = "YES" ]; then
+		if [ "${apply_needed}" = "YES" ]; then
+			if [ "${running}" = "YES" ]; then
+				cell_cid=$(cell_cid_by_name "${name}" || true)
+				if [ -z "${cell_cid}" ]; then
+					state_write "${STATE_DIR}/last_reconcile_result" "error:quiesce"
+					emit_reconcile_result "${name}" "FAILED" "quiesce"
+					return 1
+				fi
+				if ! run_reconcile_step "quiesce supervised service" stop_cell_processes "${name}" "${cell_cid}"; then
+					state_write "${STATE_DIR}/last_reconcile_result" "error:quiesce"
+					emit_reconcile_result "${name}" "FAILED" "quiesce"
+					return 1
+				fi
+			fi
+		else
+			if ! cell_exists "${name}"; then
+				if [ "${RECONCILE_SILENT}" = "YES" ]; then
+					printf 'Starting cell: %s.\n' "${name}"
+				fi
+				if ! run_reconcile_step "start service" start_cell "${name}"; then
+					state_write "${STATE_DIR}/last_reconcile_result" "error:start"
+					emit_reconcile_result "${name}" "FAILED" "start"
+					return 1
+				fi
+			elif [ "${service_changed}" = "YES" ]; then
+				if ! run_reconcile_step "restart service" restart_cell "${name}"; then
+					state_write "${STATE_DIR}/last_reconcile_result" "error:restart"
+					emit_reconcile_result "${name}" "FAILED" "restart"
+					return 1
+				fi
+			elif [ "${policy_changed}" = "YES" ] && [ "${restart_changed}" = "YES" ]; then
+				if ! run_reconcile_step "restart service" restart_cell "${name}"; then
+					state_write "${STATE_DIR}/last_reconcile_result" "error:restart"
+					emit_reconcile_result "${name}" "FAILED" "restart"
+					return 1
+				fi
+			fi
+		fi
+	else
+		if cell_exists "${name}"; then
+			if ! run_reconcile_step "stop service" stop_cell "${name}"; then
+				state_write "${STATE_DIR}/last_reconcile_result" "error:stop"
+				emit_reconcile_result "${name}" "FAILED" "stop"
+				return 1
+			fi
+		fi
+	fi
+
+	if [ "${apply_needed}" = "YES" ]; then
+		if [ "${manifest_autostart}" = "YES" ]; then
+			if ! run_reconcile_step "apply plan" apply_cell_script "${name}" "${MANIFEST_APPLY_FILE}"; then
+				if [ "${running}" = "YES" ]; then
+					run_reconcile_step "restore service after failed apply" start_cell "${name}" || true
+				fi
+				state_write "${STATE_DIR}/last_reconcile_result" "error:apply"
+				emit_reconcile_result "${name}" "FAILED" "apply"
+				return 1
+			fi
+		else
+			if ! run_reconcile_step "apply plan (ephemeral)" apply_cell_script --ephemeral "${name}" "${MANIFEST_APPLY_FILE}"; then
+				state_write "${STATE_DIR}/last_reconcile_result" "error:apply"
+				emit_reconcile_result "${name}" "FAILED" "apply"
+				return 1
+			fi
+		fi
+		state_write "${apply_hash_file}" "${apply_hash}"
+	fi
+
+	if [ "${manifest_autostart}" = "YES" ] && [ "${apply_needed}" = "YES" ]; then
+		post_apply_step="start service after apply"
+		if [ "${running}" = "YES" ]; then
+			post_apply_step="restart service after apply"
+		fi
+		if ! run_reconcile_step "${post_apply_step}" start_cell "${name}"; then
+			state_write "${STATE_DIR}/last_reconcile_result" "error:start"
+			emit_reconcile_result "${name}" "FAILED" "start"
+			return 1
+		fi
+	fi
+
+	if [ -n "${manifest_healthcheck_cmd}" ] && [ "${manifest_autostart}" = "YES" ]; then
+		if ! run_reconcile_step "healthcheck" healthcheck_cell "${name}" "${manifest_healthcheck_cmd}"; then
+			state_write "${STATE_DIR}/last_reconcile_result" "error:healthcheck"
+			emit_reconcile_result "${name}" "FAILED" "healthcheck"
+			return 1
+		fi
+	fi
+
+	state_write "${manifest_hash_file}" "${manifest_hash}"
+	state_write "${STATE_DIR}/last_reconcile_epoch" "$(date +%s)"
+	state_write "${STATE_DIR}/last_reconcile_result" "ok"
+
+	if [ "${changed}" -ne 0 ]; then
+		emit_reconcile_result "${name}" "RESULT" "changed"
+		return 2
+	fi
+	emit_reconcile_result "${name}" "RESULT" "ok"
+	return 0
+}
+
+reconcile_all() {
+	dry_run=$1
+	reapply=$2
+	restart_changed=$3
+
+	command -v cellctl >/dev/null 2>&1 || {
+		echo "missing required tool: cellctl" >&2
+		return 1
+	}
+
+	if [ "${dry_run}" != "YES" ]; then
+		need_root
+	fi
+
+	if ! order=$(reconcile_order); then
+		return 1
+	fi
+
+	if [ -n "${RECONCILE_TARGET_NAMES}" ]; then
+		for target in ${RECONCILE_TARGET_NAMES}; do
+			if ! manifest_cell_exists "${target}"; then
+				echo "cell not found in desired state: ${target}" >&2
+				return 1
+			fi
+		done
+	fi
+
+	if [ -z "${order}" ]; then
+		echo "No manifests found in ${MANIFEST_DIR} (*.cell)"
+		return 0
+	fi
+
+	if [ -n "${RECONCILE_TARGET_NAMES}" ]; then
+
+		filtered_order=
+		for name in ${order}; do
+			if word_list_contains "${name}" "${RECONCILE_TARGET_NAMES}"; then
+				filtered_order="${filtered_order} ${name}"
+			fi
+		done
+		order=${filtered_order# }
+		if [ -z "${order}" ]; then
+			echo "No matching manifests selected"
+			return 0
+		fi
+	fi
+
+	RECONCILE_LAST_SECTION=
+	emit_reconcile_header "${dry_run}" "${reapply}" "${restart_changed}" \
+	    "${RECONCILE_VERBOSE}"
+	changes=0
+	total=0
+	changed_cells=0
+	failed_cells=0
+	if reconcile_volumes "${dry_run}"; then
+		vol_rc=0
+	else
+		vol_rc=$?
+	fi
+	case "${vol_rc}" in
+	0)
+		;;
+	2)
+		changes=1
+		changed_cells=$((changed_cells + 1))
+		;;
+	*)
+		failed_cells=$((failed_cells + 1))
+		emit_reconcile_footer "${total}" "${changed_cells}" "${failed_cells}" "${dry_run}"
+		return "${vol_rc}"
+		;;
+	esac
+	for name in ${order}; do
+		total=$((total + 1))
+		if reconcile_one_cell "${name}" "${dry_run}" "${reapply}" \
+		    "${restart_changed}"; then
+			rc=0
+		else
+			rc=$?
+		fi
+
+		case "${rc}" in
+		0)
+			;;
+		2)
+			changes=1
+			changed_cells=$((changed_cells + 1))
+			;;
+		*)
+			failed_cells=$((failed_cells + 1))
+			emit_reconcile_footer "${total}" "${changed_cells}" \
+			    "${failed_cells}" "${dry_run}"
+			return "${rc}"
+			;;
+		esac
+	done
+
+	emit_reconcile_footer "${total}" "${changed_cells}" "${failed_cells}" \
+	    "${dry_run}"
+
+	if [ "${dry_run}" = "YES" ] && [ "${changes}" -ne 0 ]; then
+		return 2
+	fi
+	return 0
+}
+
+run_reconcile_command() {
+	dry_run=NO
+	reapply=NO
+	restart_changed=NO
+	all=NO
+	target_names=
+	RECONCILE_VERBOSE=NO
+	RECONCILE_SILENT=NO
+
+	while [ $# -gt 0 ]; do
+		case "$1" in
+		--dry-run)
+			dry_run=YES
+			shift
+			;;
+		--reapply)
+			reapply=YES
+			shift
+			;;
+		--restart-changed)
+			restart_changed=YES
+			shift
+			;;
+		--all)
+			all=YES
+			shift
+			;;
+		--silent)
+			RECONCILE_SILENT=YES
+			shift
+			;;
+		--manifest-dir)
+			[ $# -ge 2 ] || {
+				usage
+				exit 1
+			}
+			MANIFEST_DIR=$2
+			shift 2
+			;;
+		-v|--verbose)
+			RECONCILE_VERBOSE=YES
+			shift
+			;;
+		-*)
+			usage
+			return 1
+			;;
+		*)
+			assert_valid_cell_name "$1"
+			target_names="${target_names} $1"
+			shift
+			;;
+		esac
+	done
+
+	if [ "${RECONCILE_SILENT}" = "YES" ] && [ "${RECONCILE_VERBOSE}" = "YES" ]; then
+		echo "apply: --silent and --verbose are mutually exclusive" >&2
+		return 1
+	fi
+
+	if [ "${all}" = "YES" ] && [ -n "${target_names}" ]; then
+		echo "apply: --all cannot be combined with explicit cell names" >&2
+		return 1
+	fi
+
+	if [ "${all}" = "YES" ] || [ -z "${target_names}" ]; then
+		RECONCILE_TARGET_NAMES=
+	else
+		RECONCILE_TARGET_NAMES=${target_names# }
+	fi
+
+	reconcile_all "${dry_run}" "${reapply}" "${restart_changed}"
+	rc=$?
+	if [ "${rc}" -eq 0 ]; then
+		return 0
+	fi
+	return "${rc}"
+}
+
+
+resolve_cellmgr_self_path() {
+	cellmgr_self=$0
+	case "${cellmgr_self}" in
+	*/*)
+		;;
+	*)
+		cellmgr_self=$(command -v -- "${cellmgr_self}" 2>/dev/null || printf '%s' "${cellmgr_self}")
+		;;
+	esac
+	case "${cellmgr_self}" in
+	/*)
+		printf '%s\n' "${cellmgr_self}"
+		;;
+	*)
+		printf '%s/%s\n' "$(pwd)" "${cellmgr_self}"
+		;;
+	esac
+}
+
+load_cellmgr_modules() {
+	cellmgr_self_path=$(resolve_cellmgr_self_path)
+	cellmgr_script_dir=${cellmgr_self_path%/*}
+	cellmgr_libdir=
+
+	for candidate in \
+	    "${cellmgr_script_dir}/lib" \
+	    "${cellmgr_script_dir}/../libexec/cellmgr" \
+	    "/usr/libexec/cellmgr"; do
+		if [ -r "${candidate}/dispatch.sh" ]; then
+			cellmgr_libdir=${candidate}
+			break
+		fi
+	done
+
+	if [ -z "${cellmgr_libdir}" ]; then
+		echo "unable to locate cellmgr module directory" >&2
+		exit 1
+	fi
+
+	for module in \
+	    common.sh \
+	    cell.sh \
+	    volume.sh \
+	    system.sh \
+	    ipc.sh \
+	    dispatch.sh; do
+		if [ ! -r "${cellmgr_libdir}/${module}" ]; then
+			echo "missing cellmgr module: ${cellmgr_libdir}/${module}" >&2
+			exit 1
+		fi
+		# shellcheck disable=SC1090
+		. "${cellmgr_libdir}/${module}"
+	done
+}
+
+load_cellmgr_modules
+
+dispatch_command "$@"
+exit "$?"
