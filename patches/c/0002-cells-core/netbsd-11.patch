+.Ar name
+.Op Cm --autostart Ar YES|NO
+.Op Cm --cmd Ar command
+.Op Cm --profile Ar low|medium|high
+.Op Cm --reserved-ports Ar port[,port...]
+.Op Cm --rlimit-nofile Ar n|unlimited
+.Op Cm --rlimit-as Ar bytes|unlimited
+.Op Cm --rlimit-core Ar bytes|unlimited
+.Op Cm --depends-on Ar dep[,dep...]
+.Op Cm --healthcheck Ar command
+.Op Cm --mount Ar volume:/target[:ro|rw]
+.Op Cm --log-facility Ar facility
+.Op Cm --stdout-level Ar level
+.Op Cm --stderr-level Ar level
+.Op Cm --log-tag Ar tag
+.Op Cm --clear-reserved-ports
+.Op Cm --clear-rlimit-nofile
+.Op Cm --clear-rlimit-as
+.Op Cm --clear-rlimit-core
+.Op Cm --clear-depends-on
