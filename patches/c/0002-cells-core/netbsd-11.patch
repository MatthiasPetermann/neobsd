+static size_t cell_name_column_width(const struct cell_info *entries,
+                                     size_t count) {
+  size_t i;
+  size_t width;
+
+  width = strlen("NAME");
+  for (i = 0; i < count; i++) {
+    const char *name;
+    size_t n;
+
+    name = entries[i].ci_name[0] != '\0' ? entries[i].ci_name : "-";
+    n = strlen(name);
+    if (n > width)
+      width = n;
+  }
+
+  return width;
