+#	$NetBSD$
+#
+# /etc/cellmgr.conf -- defaults for cellmgr(8)
+#
+# RELEASE and MACHINE_ARCH can be left empty to auto-detect from the
+# running host (recommended).
+#
+# If RELEASE is set explicitly, use a valid NetBSD release directory name
+# (e.g. 11.0, 11.0_RC1). Avoid branch/source suffixes like _STABLE.
+#
+
+RELEASE=
+MACHINE_ARCH=
+
+# Optional override. If unset/empty, cellmgr derives:
+# https://cdn.netbsd.org/pub/NetBSD/NetBSD-${RELEASE}/${MACHINE_ARCH}/binary/sets
+NETBSD_MIRROR=""
+
+CELL_BASE_DIR=/var/cellmgr/base
+CELL_DATA_DIR=/var/cellmgr/cells
+CELL_VOLUME_DIR=/var/cellmgr/volumes
+CELL_BACKUP_DIR=/var/backups/cellmgr
+CELL_RELEASE_DIR=/var/cellmgr/releases
+# Declarative source-of-truth root used by `cellmgr apply`
+CELLMGR_MANIFEST_DIR=/etc/cellmgr
+
+# Package source for declarative APPLY plans.
+# PKG_RELEASE is normalized to major.minor by default (without suffixes).
+# Example normalized path:
+#   http://cdn.NetBSD.org/pub/pkgsrc/packages/NetBSD/x86_64/11.0/All
+PKG_MIRROR=http://cdn.NetBSD.org/pub/pkgsrc/packages/NetBSD
+PKG_ARCH=
+PKG_RELEASE=
+PKG_PATH=
+
+# Declarative manifests are stored as:
+#   ${CELLMGR_MANIFEST_DIR}/<name>.cell
+# Optional per-cell apply plans:
+#   ${CELLMGR_MANIFEST_DIR}/<name>.apply
+# Optional volume manifests:
+#   ${CELLMGR_MANIFEST_DIR}/<name>.volume
+
+# Per-cell local /dev setup (tmpfs + MAKEDEV)
+CELL_LOCAL_DEV=YES
+CELL_DEV_SIZE=8m
+CELL_DEVICES="std ptm"
+CELL_PTYFS=YES
