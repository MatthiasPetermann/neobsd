+
+	raw = NULL;
+	runerr = NULL;
+	if (run_argv_capture((const char *const[]){ "id", "-G",
+	    user, NULL }, &raw, &runerr) != 0) {
+		if (err != NULL)
+			*err = cellman_xasprintf(NULL, "%s",
+			    runerr != NULL ? runerr : "failed to resolve host groups");
+		free(raw);
+		free(runerr);
+		return -1;
+	}
+
+	if (add_gid_tokens_from_text(raw, out, err) != 0) {
+		free(raw);
+		free(runerr);
+		return -1;
+	}
+
+	free(raw);
+	free(runerr);
