+
+	for (i = 0;
+	    i < sizeof(volume_field_defs) / sizeof(volume_field_defs[0]); i++) {
+		if (view == READ_VIEW_MERGED ||
+		    (view == READ_VIEW_DESIRED && volume_field_defs[i].in_desired) ||
