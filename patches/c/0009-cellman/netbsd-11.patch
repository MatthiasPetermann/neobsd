diff --git a/usr.sbin/cellman/api/cmd_dispatch.c b/usr.sbin/cellman/api/cmd_dispatch.c
new file mode 100644
index 000000000000..d5dfbc53c104
--- /dev/null
+++ b/usr.sbin/cellman/api/cmd_dispatch.c
@@ -0,0 +1,151 @@
+/* $NetBSD$ */
+
+/*-
