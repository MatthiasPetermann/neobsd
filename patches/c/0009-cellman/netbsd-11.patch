-			if (is_bool_field(f)) {
-				if (v == "1")
-					return "YES"
-				if (v == "0")
-					return "NO"
-			}
-			if (v == "")
-				return "-"
-			return v
-		}
-		BEGIN {
-			n = split(cols, names, " ")
-			for (i = 1; i <= n; i++) {
-				headers[i] = toupper(names[i])
-				width[i] = length(headers[i])
-			}
-		}
-		{
-			rows = NR
-			for (i = 1; i <= n; i++) {
-				val = humanize(names[i], $i)
-				cell[NR, i] = val
-				if (length(val) > width[i])
-					width[i] = length(val)
-			}
-		}
-		END {
-			for (i = 1; i <= n; i++) {
-				printf "%-*s", width[i], headers[i]
-				if (i < n)
-					printf "  "
-				else
-					printf "\n"
-			}
-			for (r = 1; r <= rows; r++) {
-				for (i = 1; i <= n; i++) {
-					printf "%-*s", width[i], cell[r, i]
-					if (i < n)
-						printf "  "
-					else
-						printf "\n"
-				}
-			}
-		}
