+static void
+field_to_upper(const char *name, char *out, size_t outsz)
+{
+	size_t i;
+
+	if (outsz == 0)
+		return;
+
+	for (i = 0; i + 1 < outsz && name[i] != '\0'; i++)
+		out[i] = (char)toupper((unsigned char)name[i]);
+	out[i] = '\0';
+}
