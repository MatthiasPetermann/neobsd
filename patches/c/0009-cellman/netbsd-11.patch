+static bool
+field_name_token_valid(const char *token)
+{
+	size_t i;
+
+	if (token == NULL || token[0] == '\0')
+		return false;
+
+	for (i = 0; token[i] != '\0'; i++) {
+		if (!(islower((unsigned char)token[i]) ||
+		    isdigit((unsigned char)token[i]) || token[i] == '_'))
+			return false;
+	}
+
+	return true;
+}
