-runtime_field_allowed() {
-	view=$1
-	field=$2
-	case "${view}:${field}" in
-	merged:*)
-		return 0
-		;;
-	desired:name|desired:desired_state|desired:autostart|desired:create_profile|desired:create_reserved_ports|desired:create_rlimit_nofile|desired:create_rlimit_as|desired:create_rlimit_core|desired:depends_on|desired:healthcheck|desired:supervise_cmd|desired:supervise_run_as|desired:volume_mounts|desired:manifest|desired:apply_present)
-		return 0
