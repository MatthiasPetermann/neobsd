+++ b/usr.sbin/cellman/commands/command_cell.c
@@ -0,0 +1,359 @@
+/* $NetBSD$ */
+
+/*-
+ * Copyright (c) 2026 Matthias Petermann
+ * All rights reserved.
+ *
