+/* Validate token identifiers (alnum and underscore only). */
+static bool
+token_name_valid(const char *name)
+{
+	size_t i;
+
+	if (name == NULL || name[0] == '\0')
+		return false;
+
+	for (i = 0; name[i] != '\0'; i++) {
+		if (!(isalnum((unsigned char)name[i]) || name[i] == '_'))
+			return false;
+	}
+
+	return true;
+}
