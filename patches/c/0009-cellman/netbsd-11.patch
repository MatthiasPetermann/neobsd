+static bool
+destroy_error_is_busy(const char *msg)
+{
+	if (msg == NULL)
+		return false;
+
+	return strstr(msg, "Device busy") != NULL ||
+	    strstr(msg, "device busy") != NULL ||
+	    strstr(msg, "EBUSY") != NULL ||
+	    strstr(msg, "busy") != NULL;
