+static bool
+copy_opt_string(lua_State *L, int opts_idx, int out_idx, const char *key)
+{
+	int aopts;
+	int aout;
+
+	aopts = lua_absindex(L, opts_idx);
+	aout = lua_absindex(L, out_idx);
+
+	lua_getfield(L, aopts, key);
+	if (lua_isnil(L, -1)) {
+		lua_pop(L, 1);
+		return true;
+	}
+	if (!lua_isstring(L, -1)) {
+		lua_pop(L, 1);
+		return false;
+	}
+	lua_setfield(L, aout, key);
+	return true;
+}
